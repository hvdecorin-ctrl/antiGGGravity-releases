<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================ -->
    <!-- antiGGGravity PREMIUM BRAND STANDARDS (Classic Restore)        -->
    <!-- Updated to exactly mirror the original Quick VG aesthetics    -->
    <!-- ============================================================ -->

    <!-- Original 4-Stop Brand Gradient -->
    <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4A708B" Offset="0.0"/>
        <GradientStop Color="#5A8A8A" Offset="0.4"/>
        <GradientStop Color="#8B8B4A" Offset="0.7"/>
        <GradientStop Color="#B4A050" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- Original Border Brush -->
    <SolidColorBrush x:Key="PremiumBorderBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#4A708B"/>
    <SolidColorBrush x:Key="BrandSecondaryBrush" Color="#5A8A8A"/>

    <!-- ============================================================ -->
    <!-- COMPANY IDENTITY — Change these to rebrand everything        -->
    <!-- ============================================================ -->
    <sys:String x:Key="CompanyName" xmlns:sys="clr-namespace:System;assembly=System.Runtime">antiGGGravity</sys:String>

    <!-- Company Logo TextBlock Style (shown top-left in gradient headers) -->
    <Style x:Key="CompanyLogoStyle" TargetType="TextBlock">
        <Setter Property="Text" Value="{StaticResource CompanyName}"/>
        <Setter Property="FontSize" Value="18"/>    <!-- Company name: Anchor size -->
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FFF8E8"/>  <!-- Warm white: bridges blue-to-gold gradient -->
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="1.0"/>
    </Style>

    <!-- Company Pipe Divider (between logo and tool name) -->
    <Style x:Key="CompanyDividerStyle" TargetType="TextBlock">
        <Setter Property="Text" Value="|"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="#80FFFFFF"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="12,0"/>
        <Setter Property="FontWeight" Value="Thin"/>
    </Style>

    <!-- Company Footer Label -->
    <Style x:Key="CompanyFooterStyle" TargetType="TextBlock">
        <Setter Property="Text" Value="{StaticResource CompanyName}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#AAAAAA"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>

    <!-- Typography (Tool title — smaller than company name) -->
    <Style x:Key="PremiumTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>    <!-- 14/18 = 0.78 hierarchy ratio vs company name -->
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#E0EFFF"/>  <!-- Cool blue-white: contrasts with warm company name -->
    </Style>

    <Style x:Key="PremiumSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <Style x:Key="PremiumSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- Original Universal Button Style (Square, White, Blue Hover) -->
    <ControlTemplate x:Key="PremiumButtonTemplate" TargetType="Button">
        <Border x:Name="border" 
                Background="{TemplateBinding Background}" 
                BorderBrush="{TemplateBinding BorderBrush}" 
                BorderThickness="{TemplateBinding BorderThickness}" 
                CornerRadius="0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#D9EBFF"/> 
                <Setter TargetName="border" Property="BorderBrush" Value="#0078D7"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#CCE4F7"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#005A9E"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="BorderBrush" Value="#D9D9D9"/>
                <Setter TargetName="border" Property="Background" Value="#F2F2F2"/>
                <Setter Property="Foreground" Value="#A6A6A6"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="#ABADB3"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="15,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource PremiumButtonTemplate}"/>
    </Style>

    <Style x:Key="PremiumActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PremiumPrimaryButtonStyle}">
        <!-- Same as primary in the classic style -->
    </Style>

    <Style x:Key="PremiumSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PremiumPrimaryButtonStyle}">
        <Setter Property="Background" Value="#F8F8F8"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="BorderBrush" Value="#DEDEDE"/>
    </Style>

    <!-- Rounded Button Template (CornerRadius 6) for Standard File Buttons -->
    <ControlTemplate x:Key="PremiumRoundedButtonTemplate" TargetType="Button">
        <Border x:Name="border" 
                Background="{TemplateBinding Background}" 
                BorderBrush="{TemplateBinding BorderBrush}" 
                BorderThickness="{TemplateBinding BorderThickness}" 
                CornerRadius="6">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#EAEAEA"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#CCCCCC"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#D5D5D5"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="PremiumStandardFileButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="#F2F2F2"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="BorderBrush" Value="#DEDEDE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource PremiumRoundedButtonTemplate}"/>
    </Style>

    <!-- UI Elements -->
    <Style x:Key="PremiumTextBoxStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource PremiumBorderBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrandPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PremiumListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="#F0F0F0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F5F9FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#EBF3FF"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#D0E3FF"/>
                            <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PremiumListBoxStyle" TargetType="ListBox">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource PremiumBorderBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource PremiumListBoxItemStyle}"/>
    </Style>

    <!-- Transparent Icon Button Style (For Close Buttons on Gradients) -->
    <Style x:Key="PremiumIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/> <!-- Semi-transparent white hover -->
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window Outer Border -->
    <Style x:Key="PremiumBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource PremiumBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <!-- Standardized Window Chrome with Improved Resizing (10px border) -->
    <WindowChrome x:Key="PremiumWindowChrome" 
                  CaptionHeight="55" 
                  CornerRadius="12" 
                  GlassFrameThickness="0" 
                  ResizeBorderThickness="15"/>

    <GridLength x:Key="PremiumHeaderHeight">55</GridLength>

    <!-- Standardized Margins -->
    <Thickness x:Key="PremiumContentMargin">20,15,20,20</Thickness>
    <Thickness x:Key="PremiumSidebarMargin">15,15,15,20</Thickness>
    
    <!-- Premium Tab Button Style (For horizontal filters - Level 3 Pills) -->
    <Style x:Key="PremiumTabButtonStyle" TargetType="RadioButton">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Background" Value="#FAFAFA"/>
        <Setter Property="Foreground" Value="#777777"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- Soft blue background with dark blue text for Level 3 -->
                            <Setter TargetName="border" Property="Background" Value="#E6F0FA"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#BBD1EA"/>
                            <Setter Property="Foreground" Value="#2A4D6B"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Premium Light Tab Button Style (For sub-tabs like Views & Sheets - Level 2 Underline) -->
    <Style x:Key="PremiumLightTabButtonStyle" TargetType="RadioButton">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#777777"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#4A759C"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- Primary Blue Underline for Level 2 -->
                            <Setter TargetName="border" Property="BorderBrush" Value="#4A759C"/>
                            <Setter Property="Foreground" Value="#4A759C"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Premium Sidebar Button Style (Centralized) -->
    <Style x:Key="PremiumSidebarButtonStyle" TargetType="RadioButton">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#444444"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="0" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F2F2F2"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#4A759C"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    

</ResourceDictionary>
