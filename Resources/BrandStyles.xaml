<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================ -->
    <!-- antiGGGravity Brand Standards                                 -->
    <!-- Shared resource dictionary for consistent UI across all views -->
    <!-- ============================================================ -->

    <!-- Brand Gradient Brush (from ColorSplasher) -->
    <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4A708B" Offset="0.0"/>
        <GradientStop Color="#5A8A8A" Offset="0.4"/>
        <GradientStop Color="#8B8B4A" Offset="0.7"/>
        <GradientStop Color="#B4A050" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- Brand Colors -->
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#4A708B"/>
    <SolidColorBrush x:Key="BrandAccentBrush" Color="#0078D7"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SubtitleBrush" Color="#666666"/>
    <SolidColorBrush x:Key="StatusBrush" Color="#999999"/>
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#DDE0E3"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#DDE0E3"/>

    <!-- Standard Dimensions (GridLength safest for RowDefinitions) -->
    <GridLength x:Key="HeaderHeight">70</GridLength>
    <GridLength x:Key="FooterHeight">70</GridLength>
    <sys:Double x:Key="StandardBtnHeight" xmlns:sys="clr-namespace:System;assembly=mscorlib">36</sys:Double>
    <Thickness x:Key="ContentMargin">25</Thickness>
    <Thickness x:Key="HeaderPadding">25,0</Thickness>
    <Thickness x:Key="FooterPadding">25,0</Thickness>

    <!-- Typography Standards -->
    <sys:Double x:Key="TitleFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">18</sys:Double>
    <sys:Double x:Key="SubTitleFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="SectionFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
    <sys:Double x:Key="StandardFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="SmallFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="ButtonFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>

    <FontWeight x:Key="TitleFontWeight">Bold</FontWeight>
    <FontWeight x:Key="SectionFontWeight">SemiBold</FontWeight>
    <FontWeight x:Key="StandardFontWeight">Normal</FontWeight>
    <FontWeight x:Key="LabelFontWeight">Normal</FontWeight>

    <!-- Brand Title Style -->
    <Style x:Key="BrandTitleStyle" TargetType="TextBlock">
        <Setter Property="Text" Value="antiGravity"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource BrandGradientBrush}"/>
    </Style>

    <!-- Brand Subtitle Style -->
    <Style x:Key="BrandSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="{StaticResource SubtitleBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Section Label Style -->
    <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ============================================================ -->
    <!-- BUTTON STYLES (Standardized Bordered Look)                   -->
    <!-- All buttons now share the same geometry (Border + White BG)    -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- BUTTON STYLES (Single Universal Style)                       -->
    <!-- Strict enforcement: All buttons look identical (No Colors)   -->
    <!-- ============================================================ -->

    <!-- Universal Button Template -->
    <ControlTemplate x:Key="UniversalButtonTemplate" TargetType="Button">
        <Border x:Name="border" 
                Background="{TemplateBinding Background}" 
                BorderBrush="{TemplateBinding BorderBrush}" 
                BorderThickness="{TemplateBinding BorderThickness}" 
                CornerRadius="0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#D9EBFF"/> <!-- Distinct Light Blue Hover -->
                <Setter TargetName="border" Property="BorderBrush" Value="#0078D7"/> <!-- Active Blue Border -->
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#CCE4F7"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#005A9E"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="BorderBrush" Value="#D9D9D9"/>
                <Setter TargetName="border" Property="Background" Value="#F2F2F2"/>
                <Setter Property="Foreground" Value="#A6A6A6"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Primary Button (Mapped to Universal) -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="28"/> <!-- Standard Revit button height -->
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/> <!-- No Color -->
        <Setter Property="BorderBrush" Value="#ABADB3"/> <!-- Standard Grey Border -->
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="15,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource UniversalButtonTemplate}"/>
    </Style>

    <!-- Secondary Button (Mapped to Universal) -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}"/>

    <!-- Danger Button (Mapped to Universal - No Red) -->
    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}"/>

    <!-- Status Label Style -->
    <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource StatusBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Filter TextBox Style -->
    <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Generic Input Style (Same as FilterTextBox but generic name) -->
    <Style x:Key="InputStyle" TargetType="TextBox" BasedOn="{StaticResource FilterTextBoxStyle}"/>

    <!-- Section Border Style -->
    <Style x:Key="SectionBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="15"/>
    </Style>

</ResourceDictionary>
