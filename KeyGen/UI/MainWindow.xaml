<Window x:Class="antiGGGravity.KeyGenUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="antiGGGravity KeyGen (PRIVATE)" Height="450" Width="480"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}"
        ResizeMode="NoResize">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="License Key Generator" FontSize="24" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,5"/>
            <TextBlock Text="Paste the client's Hardware ID below to generate an activation key. Do NOT share this app." 
                       Foreground="#6C757D" TextWrapping="Wrap" FontSize="12"/>
        </StackPanel>

        <!-- HWID -->
        <TextBlock Grid.Row="1" Text="1. Client Hardware ID" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtHWID" Grid.Row="2" Height="40" Margin="0,0,0,20" TextChanged="Inputs_Changed" />

        <!-- Duration -->
        <TextBlock Grid.Row="3" Text="2. License Duration (Days)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
        <Grid Grid.Row="4" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBox x:Name="TxtDays" Grid.Column="0" Height="40" Text="365" Margin="0,0,10,0" TextChanged="Inputs_Changed" />
            
            <Button x:Name="Btn30Days" Grid.Column="1" Content="30 Days" Background="#E9ECEF" Foreground="#495057" Margin="0,0,10,0" Height="40" Click="BtnQuickDays_Click" />
            <Button x:Name="Btn999Days" Grid.Column="2" Content="Lifetime" Background="#E9ECEF" Foreground="#495057" Height="40" Click="BtnQuickDays_Click" />
        </Grid>

        <!-- Action Base -->
        <Grid Grid.Row="5" Margin="0,0,0,20">
            <Button x:Name="BtnGenerate" Content="Generate &amp; Copy Key" Height="45" Click="BtnGenerate_Click" />
        </Grid>

        <!-- Output -->
        <Border Grid.Row="6" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="15" MinHeight="80">
            <StackPanel>
                <TextBlock Text="Generated Activation Key:" FontWeight="SemiBold" FontSize="12" Foreground="#6C757D" Margin="0,0,0,10"/>
                <TextBox x:Name="TxtResult" Foreground="#198754" FontWeight="Bold" Background="Transparent" BorderThickness="0" 
                         FontSize="14" Padding="0" IsReadOnly="True" TextWrapping="Wrap" MinHeight="40" Text="Ready." />
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="8" Margin="-30,20,-30,-30" Background="#F8F9FA" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusCircle" Width="10" Height="10" Fill="#6C757D" Margin="5,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Checking security environment..." Foreground="#495057" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
