## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
Distribute/
*.zip

# Visual Studio 2015/2017 cache/options directory
.vs/

# Others
*.cache
*.log
*.tmp
*.bak
*.old
*.obj
*.pdb
# Binary files (Ignore by default, but unignore for KeyGen_App)
*.exe
*.dll
!/KeyGen_App/*.exe
!/KeyGen_App/*.dll
!/KeyGen_App/*.json

# AppData / Temporary
.gemini/
#! .agent/ (Unignored to allow session protocols and skills)
*.user
*.bak

# Revit Addin Specifics
*.addin
!antiGGGravity.addin

# Private KeyGen Apps (Unignored for GitHub synchronization as requested)
!KeyGen_App/
KeyGen/
KeyGenUI/

# Project Build Logs
build_errors.log
build_errors.txt
build_errors*.txt
build_log.txt
build_log_*.txt
build_output.txt
build.log
msbuild.log
pushbuttons.txt
errors_only.txt
