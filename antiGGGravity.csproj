<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <LangVersion>latest</LangVersion>
    <AssemblyName>antiGGGravity</AssemblyName>
    <RootNamespace>antiGGGravity</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="antiGGGravity.Commands" />
    <Using Include="antiGGGravity.Utilities" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Drawing.Common" Version="10.0.2" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
    <PackageReference Include="Autodesk.Revit.SDK.Refs.2026" Version="1.2.0" />
  </ItemGroup>

  <!-- Remove absolute references -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <!-- The NuGet package handles RevitAPI, RevitAPIUI, and StructuralDBAPI for us -->
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Icons\**\*.png" />
    <Resource Include="Resources\beam_cut_diagram.png" />
    <EmbeddedResource Include="Resources\ribbon.yaml" />
  </ItemGroup>

  <!-- Exclude Python reference source from compilation -->
  <ItemGroup>
    <None Remove="Reference\**" />
    <Compile Remove="Reference\**" />
    <EmbeddedResource Remove="Reference\**" />
    <Page Remove="Reference\**" />
    <Resource Remove="Reference\**" />
  </ItemGroup>

  <PropertyGroup>
    <!-- Set to false to prevent automatic copy to Revit Addins folder during regular builds -->
    <!-- We set default to false so F5 or dotnet build doesn't disrupt an open Revit session -->
    <DeployToRevit Condition="'$(DeployToRevit)' == ''">false</DeployToRevit>
  </PropertyGroup>

  <!-- Post-Build Event for Automatic Revit Installation -->
  <Target Name="PostBuild" AfterTargets="PostBuildEvent" Condition="'$(DeployToRevit)' == 'true'">
    <ItemGroup>
      <RevitVersions Include="2025;2026" />
      <AllOutputFiles Include="$(OutputPath)*.dll" />
    </ItemGroup>
    
    <!-- Deploy to each version if directory exists -->
    <Message Text="Deploying to Revit versions: @(RevitVersions)" Importance="high" />
    
    <MakeDir Directories="$(AppData)\Autodesk\Revit\Addins\%(RevitVersions.Identity)" 
             Condition="Exists('$(AppData)\Autodesk\Revit\Addins\%(RevitVersions.Identity)')" />
    
    <Copy SourceFiles="antiGGGravity.addin" 
          DestinationFolder="$(AppData)\Autodesk\Revit\Addins\%(RevitVersions.Identity)" 
          SkipUnchangedFiles="true"
          ContinueOnError="WarnAndContinue"
          Condition="Exists('$(AppData)\Autodesk\Revit\Addins\%(RevitVersions.Identity)')" />
    
    <Copy SourceFiles="@(AllOutputFiles)" 
          DestinationFolder="$(AppData)\Autodesk\Revit\Addins\%(RevitVersions.Identity)" 
          SkipUnchangedFiles="true"
          ContinueOnError="WarnAndContinue"
          Condition="Exists('$(AppData)\Autodesk\Revit\Addins\%(RevitVersions.Identity)')" />
  </Target>

</Project>
