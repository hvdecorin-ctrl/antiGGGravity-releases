<Window x:Class="antiGGGravity.Commands.Transfer.UI.ViewTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="View Transfer Tool" Height="700" Width="900" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <!-- Allow dragging by hooking into WindowChrome -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="70" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12" Background="#FAFAFA" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/> <!-- Header -->
                <RowDefinition Height="*"/>  <!-- Main Content -->
                <RowDefinition Height="70"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. HEADER (Gradient) -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="VIEW TRANSFER" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Selectively transfer views &amp; sheets across projects" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Close button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- 2. MAIN BODY (Scrollable) -->
            <Grid Grid.Row="1" Margin="25,20,25,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Source File Picker -->
                <GroupBox Header="1. Select Source Document" Grid.Row="0" Margin="0,0,0,15">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SourceFilePath, Mode=TwoWay}" VerticalAlignment="Center" Height="28" IsReadOnly="True" />
                        <Button Grid.Column="1" Content="Browse..." Width="90" Height="28" Margin="10,0,0,0" Click="BrowseFile_Click" Style="{StaticResource PremiumPrimaryButtonStyle}"/>
                    </Grid>
                </GroupBox>

                <!-- Settings -->
                <GroupBox Header="2. Transfer Settings" Grid.Row="1" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <CheckBox Content="Add Prefix to duplicates:" IsChecked="{Binding Options.DuplicateHandlingPrefix}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding Options.PrefixString}" Width="100" Height="24" IsEnabled="{Binding Options.DuplicateHandlingPrefix}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Checkboxes/Grids -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Views Column -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Category Filters -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton Content="All" Command="{Binding SetCategoryCommand}" CommandParameter="All" IsChecked="{Binding IsAllSelected}" Style="{StaticResource PremiumTabButtonStyle}" Width="60"/>
                                <RadioButton Content="Detail" Command="{Binding SetCategoryCommand}" CommandParameter="Detail" IsChecked="{Binding IsDetailSelected}" Style="{StaticResource PremiumTabButtonStyle}" Width="80" Margin="8,0,0,0"/>
                                <RadioButton Content="Drafting" Command="{Binding SetCategoryCommand}" CommandParameter="Drafting" IsChecked="{Binding IsDraftingSelected}" Style="{StaticResource PremiumTabButtonStyle}" Width="90" Margin="8,0,0,0"/>
                                <RadioButton Content="Legend" Command="{Binding SetCategoryCommand}" CommandParameter="Legend" IsChecked="{Binding IsLegendSelected}" Style="{StaticResource PremiumTabButtonStyle}" Width="80" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- View Search -->
                            <Border Margin="0,0,0,8" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1" Grid.Row="0">
                                <Grid Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding ViewSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             BorderThickness="0" Background="Transparent" VerticalAlignment="Center" 
                                             Style="{StaticResource PremiumTextBoxStyle}" Margin="0"/>
                                </Grid>
                            </Border>

                            <GroupBox Header="3. Drafting &amp; Views" Grid.Row="1">
                                <DataGrid ItemsSource="{Binding FilteredViews}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="✓" Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Type" Binding="{Binding ViewType}" Width="100" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Name" Binding="{Binding ViewName}" Width="*" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>

                        <!-- Sheets Column -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Sheet Search -->
                            <Border Margin="0,0,0,8" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                <Grid Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding SheetSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             BorderThickness="0" Background="Transparent" VerticalAlignment="Center"
                                             Style="{StaticResource PremiumTextBoxStyle}" Margin="0"/>
                                </Grid>
                            </Border>

                            <GroupBox Header="4. Sheets" Grid.Row="1">
                                <DataGrid ItemsSource="{Binding FilteredSheets}" SelectedItem="{Binding SelectedSheet}" 
                                          AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="✓" Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Number" Binding="{Binding SheetNumber}" Width="80" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Name" Binding="{Binding SheetName}" Width="*" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>
                    </Grid>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="Transparent" Margin="0,5"/>

                    <!-- Sheet Details -->
                    <GroupBox Header="5. Viewports In Selected Sheet" Grid.Row="2">
                        <DataGrid ItemsSource="{Binding ViewportsInSelectedSheet}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="✓" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Type" Binding="{Binding ViewType}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="View Name" Binding="{Binding ViewName}" Width="*" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </Grid>

            <!-- 3. FOOTER -->
            <Border Grid.Row="2" Padding="25,15" Background="#FAFAFA" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#999999" FontSize="12"/>
                    <Button Grid.Column="1" Content="Cancel" Style="{StaticResource PremiumPrimaryButtonStyle}" Width="90" Margin="0,0,12,0" Click="Close_Click"/>
                    <Button Grid.Column="2" Content="Transfer Selected" Style="{StaticResource PremiumActionButtonStyle}" Width="140" Click="Transfer_Click" IsEnabled="{Binding IsSourceLoaded}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
