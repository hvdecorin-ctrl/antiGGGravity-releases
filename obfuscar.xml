<?xml version="1.0"?>
<Obfuscator>
  <Var name="InPath" value=".\bin\Release\net8.0-windows" />
  <Var name="OutPath" value=".\bin\Obfuscated" />
  <Var name="HideStrings" value="true" />
  <Var name="RenameProperties" value="true" />
  <Var name="RenameEvents" value="true" />
  <Var name="RenameFields" value="true" />
  <Var name="KeepPublicApi" value="false" />
  
  <AssemblySearchPath path="C:\Program Files\dotnet\shared\Microsoft.WindowsDesktop.App\8.0.24" />
  <AssemblySearchPath path="C:\Program Files\dotnet\shared\Microsoft.NETCore.App\8.0.24" />
  <AssemblySearchPath path="C:\Program Files\Autodesk\Revit 2026" />
  <AssemblySearchPath path="C:\Program Files\Autodesk\Revit 2025" />
  <AssemblySearchPath path="C:\Program Files\Autodesk\Revit 2024" />
  <AssemblySearchPath path="C:\Program Files\Autodesk\Revit 2023" />
  <AssemblySearchPath path="C:\Program Files\Autodesk\Revit 2022" />
  
  <Module file="$(InPath)\antiGGGravity.dll">
    <!-- ============================================================ -->
    <!-- Revit API Entry Points — loaded by name, must not be renamed  -->
    <!-- ============================================================ -->
    <SkipType name="antiGGGravity.App" />
    <SkipType name="antiGGGravity.Commands.*.*$" rx="true" />
    <SkipType name="antiGGGravity.StructuralRebar.*Command$" rx="true" />

    <!-- ============================================================ -->
    <!-- YAML Deserialization Models — properties must keep names for  -->
    <!-- YamlDotNet CamelCaseNamingConvention deserialization          -->
    <!-- ============================================================ -->
    <SkipType name="antiGGGravity.Utilities.RibbonConfiguration" />
    <SkipType name="antiGGGravity.Utilities.TabConfig" />
    <SkipType name="antiGGGravity.Utilities.PanelConfig" />
    <SkipType name="antiGGGravity.Utilities.PanelItemConfig" />
    <SkipType name="antiGGGravity.Utilities.ButtonConfig" />
    <SkipType name="antiGGGravity.Utilities.RibbonConfigLoader" />

    <!-- ============================================================ -->
    <!-- WPF / Resource Loading — used by Pack URIs and XAML binding   -->
    <!-- ============================================================ -->
    <SkipType name="antiGGGravity.Utilities.SharedResources" />
    <SkipType name="antiGGGravity.Resources.Branding" />

    <!-- ============================================================ -->
    <!-- License Result public API — properties accessed via reflection -->
    <!-- ============================================================ -->
    <SkipType name="antiGGGravity.Utilities.LicenseResult" skipMethods="true" skipProperties="false" />
    <SkipType name="antiGGGravity.Utilities.LicenseKeyResult" skipMethods="true" skipProperties="false" />

    <!-- ============================================================ -->
    <!-- Auto-updater models — JSON deserialization requires property names -->
    <!-- ============================================================ -->
    <SkipType name="antiGGGravity.Utilities.UpdateInfo" />
    <SkipType name="antiGGGravity.Utilities.DownloadResult" />
  </Module>
</Obfuscator>
