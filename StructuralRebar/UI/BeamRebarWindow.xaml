<Window x:Class="antiGGGravity.StructuralRebar.UI.BeamRebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beam Reinforcement" 
        Height="900" Width="950" 
        MinHeight="700" MinWidth="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="10"/>
    </WindowChrome.WindowChrome>

    
    <!-- Resources are merged in code-behind via SharedResources to prevent latency -->
    
    <Border Style="{StaticResource PremiumBorderStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Beam Reinforcement" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Structural rebar generator for beams" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Button_Cancel_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,0,1,0">
                    <StackPanel Margin="{StaticResource PremiumSidebarMargin}">
                        <TextBlock Text="Sub-Category" FontSize="11" FontWeight="SemiBold" Foreground="#888888" Margin="8,0,0,10"/>
                        
                        <RadioButton x:Name="UI_Radio_Beam" Content="Beam Standard" IsChecked="True"
                                     GroupName="ElementType" Style="{StaticResource PremiumSidebarButtonStyle}"
                                     Checked="ElementType_Changed"/>
                        <RadioButton x:Name="UI_Radio_BeamAdvance" Content="Beam Advance" 
                                     GroupName="ElementType" Style="{StaticResource PremiumSidebarButtonStyle}"
                                     Checked="ElementType_Changed"/>

                        <Separator Margin="5,10,5,10" Background="#E0E0E0"/>

                        <TextBlock Text="Options" FontSize="11" FontWeight="SemiBold" Foreground="#888888" Margin="8,0,0,10"/>
                        <CheckBox x:Name="UI_Check_RemoveExisting" Content="Remove Existing" FontSize="13" Foreground="#555" Margin="8,0,0,8" IsChecked="True"/>
                        <CheckBox x:Name="UI_Check_CutRebar" Content="Cut Rebar (>12m)" FontSize="13" Foreground="#555" Margin="8,0,0,8" IsChecked="True"
                                  Checked="CutRebar_Changed" Unchecked="CutRebar_Changed"/>

                        <!-- Splice Zone Settings (visible when Cut Rebar is checked) -->
                        <StackPanel x:Name="UI_SpliceZonePanel" Margin="20,0,8,8">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Top Zone" FontSize="11" Foreground="#888" Width="72" VerticalAlignment="Center"/>
                                <ComboBox x:Name="UI_Combo_TopZone" Height="24" Width="65" FontSize="11">
                                    <ComboBoxItem Content="L/3" IsSelected="True"/>
                                    <ComboBoxItem Content="L/4"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Bottom Zone" FontSize="11" Foreground="#888" Width="72" VerticalAlignment="Center"/>
                                <ComboBox x:Name="UI_Combo_BotZone" Height="24" Width="65" FontSize="11">
                                    <ComboBoxItem Content="L/4"/>
                                    <ComboBoxItem Content="L/5" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>

                        <CheckBox x:Name="UI_Check_B2Cantilever" Content="B2 → Cantilever" FontSize="13" Foreground="#555" Margin="8,0,0,8" IsChecked="True"
                                  ToolTip="Extend B2 bottom bars into cantilever zones"/>

                        <Separator Margin="5,0,5,10" Background="#E0E0E0"/>
                        
                        <TextBlock Text="Design Code" FontSize="11" FontWeight="SemiBold" Foreground="#888888" Margin="8,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_DesignCode" Margin="8,0,8,10" Height="28" SelectionChanged="DesignCode_Changed">
                            <ComboBoxItem Content="ACI 318" IsSelected="True"/>
                            <ComboBoxItem Content="AS 3600"/>
                            <ComboBoxItem Content="Eurocode 2"/>
                            <ComboBoxItem Content="NZS 3101"/>
                            <ComboBoxItem Content="Custom"/>
                        </ComboBox>

                        <Button Content="📖 Beam Detailing" Height="28" FontSize="11" Foreground="#4A759C" 
                                Background="Transparent" BorderBrush="#4A759C" BorderThickness="1" 
                                Margin="8,0,8,0" Cursor="Hand" Click="UI_Button_Detailing_Click"
                                ToolTip="View standard lap splicing and detailing rules"/>
                    </StackPanel>
                </Border>

                <!-- PANEL CONTENT AREA -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <ContentControl x:Name="UI_PanelHost" Margin="{StaticResource PremiumContentMargin}"/>
                </ScrollViewer>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="#F9F9F9" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12" Padding="25,12">
                <Grid>
                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#AAAAAA" Text="antiGGGravity © 2026 HV Sponsor"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Close" Width="100" Height="36" Margin="0,0,10,0"
                                Style="{StaticResource PremiumPrimaryButtonStyle}" Click="UI_Button_Cancel_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="Generate" Width="140" Height="36"
                                Style="{StaticResource PremiumPrimaryButtonStyle}" Click="UI_Button_Generate_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
