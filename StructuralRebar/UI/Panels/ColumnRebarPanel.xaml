<UserControl x:Class="antiGGGravity.StructuralRebar.UI.Panels.ColumnRebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="700">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════ MODE SELECTOR ══════ -->
        <Border Grid.Row="0" Background="#F0F2F5" CornerRadius="8" Padding="4" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="UI_Radio_ModeColumn" Grid.Column="0" Content="Column" IsChecked="True"
                             GroupName="ColumnMode" Checked="ColumnMode_Changed"
                             FontSize="13" FontWeight="SemiBold" Foreground="#333" Cursor="Hand"
                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                             Height="34" Margin="2">
                    <RadioButton.Template>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="12,6" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="White"/>
                                    <Setter TargetName="Bd" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.15" Color="Black"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="#1A73E8"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8EAF0"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsChecked" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="White"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RadioButton.Template>
                </RadioButton>
                <RadioButton x:Name="UI_Radio_ModeMultiLevel" Grid.Column="1" Content="Multi Level Column" 
                             GroupName="ColumnMode" Checked="ColumnMode_Changed"
                             FontSize="13" FontWeight="SemiBold" Foreground="#333" Cursor="Hand"
                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                             Height="34" Margin="2">
                    <RadioButton.Template>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="12,6" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="White"/>
                                    <Setter TargetName="Bd" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.15" Color="Black"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="#1A73E8"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8EAF0"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsChecked" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="White"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RadioButton.Template>
                </RadioButton>
            </Grid>
        </Border>

        <!-- ══════ MAIN CONTENT ROW ══════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Vertical Main Bars -->
            <Border Grid.Column="0" Background="#FAFAFA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Vertical Main Bars" FontSize="14" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rebar Type X" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VerticalTypeX" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,8"/>
                            <TextBlock Text="Bars in X (Face)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_CountX" Text="3" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"
                                     TextChanged="BarCount_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Rebar Type Y" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VerticalTypeY" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,8"/>
                            <TextBlock Text="Bars in Y (Face)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_CountY" Text="3" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"
                                     TextChanged="BarCount_Changed"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Hooks &amp; Extensions" FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hook Bottom" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VHookBot" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" 
                                      SelectionChanged="HookCombo_Changed"/>
                            <CheckBox x:Name="UI_Check_VHookBotOut" Content="Bend Outward" FontSize="13" Foreground="#666666" Margin="0,10,0,15" IsChecked="False"/>
                            
                            <CheckBox x:Name="UI_Check_BotExt" Content="Bottom Ext" FontSize="13" Foreground="#666666" IsChecked="False" Margin="0,0,0,8"
                                      Checked="UpdateHooksExtHalftone" Unchecked="UpdateHooksExtHalftone"/>
                            <TextBox x:Name="UI_Text_BotExtValue" Text="300" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Margin="0,0,0,10"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hook Top" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VHookTop" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" 
                                      SelectionChanged="HookCombo_Changed"/>
                            <CheckBox x:Name="UI_Check_VHookTopOut" Content="Bend Outward" FontSize="13" Foreground="#666666" Margin="0,10,0,15" IsChecked="False"/>
                            
                            <CheckBox x:Name="UI_Check_TopExt" Content="Top Ext" FontSize="13" Foreground="#666666" IsChecked="False" Margin="0,0,0,8"
                                      Checked="UpdateHooksExtHalftone" Unchecked="UpdateHooksExtHalftone"/>
                            <TextBox x:Name="UI_Text_TopExtValue" Text="300" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CENTER: CROSS-SECTION PREVIEW -->
            <Border Grid.Column="2" Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15" Width="180">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Cross Section" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Canvas x:Name="UI_CrossSectionCanvas" Width="140" Height="140" Background="Transparent" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="UI_CrossSectionLabel" Text="3×3" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Ties / Stirrups -->
            <Border Grid.Column="4" Background="#FAFAFA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Ties / Stirrups" FontSize="14" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rebar Type" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_TieType" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Spacing" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TieSpacing" Text="200" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Rule Offsets" FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Top Offset" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TieTopOffset" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Bottom Offset" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TieBotOffset" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Margin="0,0,0,15"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Hooks Configuration" FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hook Start" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookStart" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hook End" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookEnd" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Tie Distribution" FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,15,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="UI_Radio_TieEQ" Content="Equal (EQ)" IsChecked="True" GroupName="TieDist" 
                                     FontSize="12" Foreground="#333" Margin="0,0,20,0" Click="TieDist_Changed"/>
                        <RadioButton x:Name="UI_Radio_TieUnEQ" Content="Unequal (Code)" GroupName="TieDist" 
                                     FontSize="12" Foreground="#333" Click="TieDist_Changed"/>
                    </StackPanel>

                    <!-- Zone Info (visible when UnEQ selected) -->
                    <Border x:Name="UI_TieZoneInfo" Background="#EDF6FF" CornerRadius="4" BorderBrush="#C8DFF0" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock x:Name="UI_TieZoneTitle" Text="3-Zone Layout (ACI 318):" FontSize="11" FontWeight="SemiBold" Foreground="#3A6D99" Margin="0,0,0,6"/>
                            <TextBlock x:Name="UI_TieZoneLine1" Text="├─ Bottom Confinement: l_o length, s_o spacing" FontSize="10" Foreground="#555" FontFamily="Consolas"/>
                            <TextBlock x:Name="UI_TieZoneLine2" Text="├─ Mid Span:           H-2×l_o,   2×s_o"       FontSize="10" Foreground="#555" FontFamily="Consolas"/>
                            <TextBlock x:Name="UI_TieZoneLine3" Text="└─ Top Confinement:    l_o length, s_o spacing" FontSize="10" Foreground="#555" FontFamily="Consolas"/>
                            <TextBlock x:Name="UI_TieZoneNote" Text="l_o = max(H/6, D, 450mm), s_o = min(D/4, 6db, 150mm)" FontSize="9" Foreground="#888" Margin="0,6,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════ BOTTOM ROW: MULTI-LEVEL & STARTER BARS ══════ -->
        <Grid x:Name="UI_BottomRow" Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="UI_ColMultiLevel" Width="*"/>
                <ColumnDefinition x:Name="UI_ColSpacer" Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Multi-Level Processing (only visible in Multi Level mode) -->
            <Border x:Name="UI_Border_MultiLevel" Grid.Column="0" Background="#FAFAFA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Multi-Level Processing" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <StackPanel x:Name="UI_Panel_MultiLevelFields">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Splice Position" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_SplicePos" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Above Slab" IsSelected="True"/>
                                    <ComboBoxItem Content="Mid Height"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Crank Position" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_CrankPos" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Upper Column" IsSelected="True"/>
                                    <ComboBoxItem Content="Lower Column"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Lap Length Mode" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_LapMode" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,4"
                                          SelectionChanged="UI_Combo_LapMode_Changed">
                                    <ComboBoxItem Content="Auto (Code)" IsSelected="True"/>
                                    <ComboBoxItem Content="Manual"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Manual Lap" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBox x:Name="UI_Text_LapSplice" Text="40" Height="32" Width="60" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" />
                                    <TextBlock Text="x Dia Bar" FontSize="12" Foreground="#666666" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Starter Bars -->
            <Border Grid.Column="2" Background="#FAFAFA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <!-- Header row with toggle checkbox -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="UI_Check_Starters" Content="Foundation Starters" FontSize="13" Foreground="#333333" FontWeight="SemiBold"
                                  VerticalAlignment="Center" Grid.Column="0"
                                  Checked="Starters_Changed" Unchecked="Starters_Changed"/>
                        <CheckBox x:Name="UI_Check_StarterOnly" Content="Starter Only" FontSize="12" Foreground="#4A708B" FontWeight="SemiBold"
                                  VerticalAlignment="Center" Grid.Column="2" IsChecked="False" ToolTip="Generate starter bars only (skip vertical bars and ties)"
                                  Checked="Starters_Changed" Unchecked="Starters_Changed"/>
                    </Grid>

                    <!-- Collapsible starter fields -->
                    <StackPanel x:Name="UI_Panel_StarterFields">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bar Type" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_StarterType" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Hook End" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_StarterHook" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Dev Length (mm)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <TextBox x:Name="UI_Text_StarterDevLength" Text="0" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                            </StackPanel>
                        </Grid>
                        
                        <TextBlock Text="Starter bars project below L1 into foundation. 0 = auto (code default)." FontSize="10" Foreground="#999999" Margin="0,5,0,0" FontStyle="Italic" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
