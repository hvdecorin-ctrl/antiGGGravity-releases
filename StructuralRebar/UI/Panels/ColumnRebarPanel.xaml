<UserControl x:Class="antiGGGravity.StructuralRebar.UI.Panels.ColumnRebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: VERTICAL MAIN BARS -->
        <StackPanel Grid.Column="0">
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Vertical Main Bars" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rebar Type X" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VerticalTypeX" Height="32" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Bars in X-Dir (Face)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_CountX" Text="3" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Rebar Type Y" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VerticalTypeY" Height="32" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Bars in Y-Dir (Face)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_CountY" Text="3" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bottom Hook" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VHookBot" Height="32" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,8" />
                            <CheckBox x:Name="UI_Check_VHookBotOut" Content="Bend Outward" IsChecked="True" FontSize="11" Foreground="#666666" Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="UI_Check_BotExt" IsChecked="True" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Bottom Extension (mm)" FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox x:Name="UI_Text_BotExtValue" Text="300" Height="32" VerticalContentAlignment="Center" Padding="8,0" 
                                     Visibility="{Binding IsChecked, ElementName=UI_Check_BotExt, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Top Hook" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VHookTop" Height="32" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,8" />
                            <CheckBox x:Name="UI_Check_VHookTopOut" Content="Bend Outward" IsChecked="False" FontSize="11" Foreground="#666666" Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="UI_Check_TopExt" IsChecked="False" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Top Extension (mm)" FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox x:Name="UI_Text_TopExtValue" Text="300" Height="32" VerticalContentAlignment="Center" Padding="8,0"
                                     Visibility="{Binding IsChecked, ElementName=UI_Check_TopExt, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- RIGHT COLUMN: TIES / STIRRUPS -->
        <StackPanel Grid.Column="2">
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Ties / Stirrups" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                    <ComboBox x:Name="UI_Combo_TieType" Height="32" Padding="8,0" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hook Start" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookStart" Height="32" Padding="8,0" VerticalContentAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hook End" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookEnd" Height="32" Padding="8,0" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Spacing (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                    <TextBox x:Name="UI_Text_TieSpacing" Text="200" Height="32" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bot Offset (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TieBotOffset" Text="100" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Top Offset (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TieTopOffset" Text="100" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
