<UserControl x:Class="antiGGGravity.StructuralRebar.UI.Panels.StripFootingRebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: LONGITUDINAL BARS -->
        <StackPanel Grid.Column="0">
            <!-- Top Reinforcement -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox x:Name="UI_Check_TopBars" Content="Top Reinforcement" FontWeight="Bold" Foreground="#333333" IsChecked="True" Margin="0,0,0,15" Click="toggle_visibility" Opacity="0.5"/>
                    <StackPanel x:Name="UI_Group_TopBars" IsEnabled="False" Opacity="0.5">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_TopType" Height="32" Padding="8,0" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Count" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                <TextBox x:Name="UI_Text_TopCount" Text="4" Height="32" VerticalContentAlignment="Center" Padding="8,0" TextChanged="toggle_visibility"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Hook Start/End" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_TopHook" Height="32" Padding="8,0" VerticalContentAlignment="Center" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="UI_Check_TopHookOverride" Content="Override Hook Length" FontSize="11" Foreground="#666666" VerticalAlignment="Center" Grid.Column="0"/>
                            <TextBox x:Name="UI_Text_TopHookLength" Text="300" Height="32" VerticalContentAlignment="Center" Padding="8,0" Grid.Column="2"
                                     IsEnabled="{Binding IsChecked, ElementName=UI_Check_TopHookOverride}" TextChanged="toggle_visibility"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Side/Perimeter Reinforcement (Moved from Right) -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox x:Name="UI_Check_SideRebar" Content="Side/Perimeter Reinforcement" FontWeight="Bold" Foreground="#333333" IsChecked="True" Margin="0,0,0,15" Click="toggle_visibility" Opacity="0.5"/>
                    <StackPanel x:Name="UI_Group_SideRebar" IsEnabled="False" Opacity="0.5">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_SideType" Height="32" Padding="8,0" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Rows (Each Side)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                <TextBox x:Name="UI_Text_SideRows" Text="2" Height="32" VerticalContentAlignment="Center" Padding="8,0" TextChanged="toggle_visibility"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- CENTER COLUMN: VISUALIZATION -->
        <StackPanel Grid.Column="2" VerticalAlignment="Top">
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="10" Margin="0,0,0,15">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Cross Section" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Canvas x:Name="UI_Canvas_CrossSection" Width="200" Height="190" Background="Transparent" HorizontalAlignment="Center" ClipToBounds="True"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- RIGHT COLUMN: STIRRUPS & OPTIONS -->
        <StackPanel Grid.Column="4">


            <!-- Bottom Reinforcement (Moved to Top of Column) -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox x:Name="UI_Check_BotBars" Content="Bottom Reinforcement" FontWeight="Bold" Foreground="#333333" IsChecked="True" Margin="0,0,0,15" Click="toggle_visibility" Opacity="0.5"/>
                    <StackPanel x:Name="UI_Group_BotBars" IsEnabled="False" Opacity="0.5">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_BotType" Height="32" Padding="8,0" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Count" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                <TextBox x:Name="UI_Text_BotCount" Text="4" Height="32" VerticalContentAlignment="Center" Padding="8,0" TextChanged="toggle_visibility"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Hook Start/End" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_BotHook" Height="32" Padding="8,0" VerticalContentAlignment="Center" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="UI_Check_BotHookOverride" Content="Override Hook Length" FontSize="11" Foreground="#666666" VerticalAlignment="Center" Grid.Column="0"/>
                            <TextBox x:Name="UI_Text_BotHookLength" Text="300" Height="32" VerticalContentAlignment="Center" Padding="8,0" Grid.Column="2"
                                     IsEnabled="{Binding IsChecked, ElementName=UI_Check_BotHookOverride}" TextChanged="toggle_visibility"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Stirrups / Links" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_TransType" Height="32" Padding="8,0" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Spacing (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TransSpacing" Text="200" Height="32" VerticalContentAlignment="Center" Padding="8,0" TextChanged="toggle_visibility"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hook Start" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookStart" Height="32" Padding="8,0" VerticalContentAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hook End" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookEnd" Height="32" Padding="8,0" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Start Offset (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                        <TextBox x:Name="UI_Text_TransStartOff" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0" TextChanged="toggle_visibility"/>
                    </StackPanel>
                    
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
