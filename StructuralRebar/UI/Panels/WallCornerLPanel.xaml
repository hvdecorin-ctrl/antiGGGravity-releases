<UserControl x:Class="antiGGGravity.StructuralRebar.UI.Panels.WallCornerLPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: HORIZONTAL BARS -->
        <StackPanel Grid.Column="0">
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Horizontal Corner Bars (L)" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HorizType" Height="32" Padding="8,0" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Spacing (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_HorizSpacing" Text="200" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Leg 1 Length (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_Leg1" Text="600" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Leg 2 Length (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_Leg2" Text="600" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Layer Config" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_Layers" Height="32" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Both Faces" IsSelected="True"/>
                                <ComboBoxItem Content="External Face"/>
                                <ComboBoxItem Content="Internal Face"/>
                                <ComboBoxItem Content="Centre"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- RIGHT COLUMN: VERTICAL LIMITS & TRIMMERS -->
        <StackPanel Grid.Column="2">
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Vertical Limits" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Top Offset (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TopOffset" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Bottom Offset (mm)" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_BotOffset" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#F0F5FA" BorderBrush="#D1E4F3" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel>
                            <CheckBox x:Name="UI_Check_Trimmers" Content="Add Vertical Trimmers" FontWeight="SemiBold" Foreground="#333333" IsChecked="False" Margin="0,0,0,10" Click="toggle_visibility"/>
                            <StackPanel x:Name="UI_Group_Trimmers">
                                <TextBlock Text="Trimmer Bar Type" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_TrimmerType" Height="30" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
