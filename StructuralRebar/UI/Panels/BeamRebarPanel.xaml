<UserControl x:Class="antiGGGravity.StructuralRebar.UI.Panels.BeamRebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: TOP & BOTTOM REINFORCEMENT -->
        <StackPanel Grid.Column="0">
            <!-- TOP REINFORCEMENT -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Top Reinforcement" FontSize="12" FontWeight="SemiBold" Foreground="#4A759C" Margin="0,0,0,12"/>

                    <!-- T1 -->
                    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="UI_Check_T1" Content="T1 - Top Layer 1 (Corner / Outer)" FontSize="12" Foreground="#333" FontWeight="SemiBold" Margin="0,0,0,8" Click="toggle_visibility"/>
                            <StackPanel x:Name="UI_Group_T1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_T1Type" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Count" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_T1Count" Text="2" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- T2 -->
                    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="UI_Check_T2" Content="T2 - Top Layer 2 (Inner)" FontSize="12" Foreground="#333" FontWeight="SemiBold" Margin="0,0,0,8" Click="toggle_visibility"/>
                            <StackPanel x:Name="UI_Group_T2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_T2Type" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Count" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_T2Count" Text="3" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Top Bars Hook -->
                    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Top Bars Hook" FontSize="12" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_TopHookStart" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_TopHookEnd" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="UI_Check_TopHookOverride" Content="Override Hook Length" FontSize="11" Foreground="#666" VerticalAlignment="Center" Grid.Column="0"/>
                                <TextBox x:Name="UI_Text_TopHookLength" Text="300" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Grid.Column="2"
                                         IsEnabled="{Binding IsChecked, ElementName=UI_Check_TopHookOverride}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- BOTTOM REINFORCEMENT -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15">
                <StackPanel>
                    <TextBlock Text="Bottom Reinforcement" FontSize="12" FontWeight="SemiBold" Foreground="#4A759C" Margin="0,0,0,12"/>

                    <!-- B2 -->
                    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="UI_Check_B2" Content="B2 - Bottom Layer 2 (Inner)" FontSize="12" Foreground="#333" FontWeight="SemiBold" Margin="0,0,0,8" Click="toggle_visibility"/>
                            <StackPanel x:Name="UI_Group_B2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_B2Type" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Count" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_B2Count" Text="3" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- B1 -->
                    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <CheckBox x:Name="UI_Check_B1" Content="B1 - Bottom Layer 1 (Corner / Outer)" FontSize="12" Foreground="#333" FontWeight="SemiBold" Margin="0,0,0,8" Click="toggle_visibility"/>
                            <StackPanel x:Name="UI_Group_B1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_B1Type" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Count" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_B1Count" Text="2" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Bottom Bars Hook -->
                    <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Bottom Bars Hook" FontSize="12" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_BotHookStart" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_BotHookEnd" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="UI_Check_BotHookOverride" Content="Override Hook Length" FontSize="11" Foreground="#666" VerticalAlignment="Center" Grid.Column="0"/>
                                <TextBox x:Name="UI_Text_BotHookLength" Text="300" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Grid.Column="2"
                                         IsEnabled="{Binding IsChecked, ElementName=UI_Check_BotHookOverride}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            

        </StackPanel>

        <!-- RIGHT COLUMN: STIRRUPS & RULE OFFSETS -->
        <StackPanel Grid.Column="2">
            <!-- STIRRUPS / LINKS -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Stirrups / Links" FontSize="12" FontWeight="SemiBold" Foreground="#4A759C" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Rebar Shape" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                    <ComboBox x:Name="UI_Combo_TransShape" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,8" IsEnabled="False">
                        <ComboBoxItem Content="00" IsSelected="True"/>
                    </ComboBox>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_TransType" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Spacing (mm)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TransSpacing" Text="200" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hook Start" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookStart" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hook End" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_HookEnd" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- STIRRUP DISTRIBUTION -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Stirrup Distribution" FontSize="12" FontWeight="SemiBold" Foreground="#4A759C" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="UI_Radio_StirrupEQ" Content="Equal (EQ)" IsChecked="True" GroupName="StirrupDist" 
                                     FontSize="12" Foreground="#333" Margin="0,0,20,0" Click="StirrupDist_Changed"/>
                        <RadioButton x:Name="UI_Radio_StirrupUnEQ" Content="Unequal (Code)" GroupName="StirrupDist" 
                                     FontSize="12" Foreground="#333" Click="StirrupDist_Changed"/>
                    </StackPanel>

                    <!-- Zone Info (visible when UnEQ selected) -->
                    <Border x:Name="UI_ZoneInfo" Background="#EDF6FF" CornerRadius="4" BorderBrush="#C8DFF0" BorderThickness="1" Padding="10" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="UI_ZoneTitle" Text="3-Zone Layout (ACI 318):" FontSize="11" FontWeight="SemiBold" Foreground="#3A6D99" Margin="0,0,0,6"/>
                            <TextBlock x:Name="UI_ZoneLine1" Text="├─ Left End Zone:  2h length, d/4 spacing" FontSize="10" Foreground="#555" FontFamily="Consolas"/>
                            <TextBlock x:Name="UI_ZoneLine2" Text="├─ Mid Zone:       remainder, user spacing" FontSize="10" Foreground="#555" FontFamily="Consolas"/>
                            <TextBlock x:Name="UI_ZoneLine3" Text="└─ Right End Zone: 2h length, d/4 spacing" FontSize="10" Foreground="#555" FontFamily="Consolas"/>
                            <TextBlock x:Name="UI_ZoneNote" Text="h = beam depth, spacing = min(h/4, s/2, 150mm)" FontSize="9" Foreground="#888" Margin="0,6,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- RULE OFFSETS -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Rule Offsets" FontSize="12" FontWeight="SemiBold" Foreground="#4A759C" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Stirrup Start Offset (mm)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                    <TextBox x:Name="UI_Text_TransStartOffset" Text="100" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                </StackPanel>
            </Border>

            <!-- SIDE REINFORCEMENT -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15">
                <StackPanel>
                    <CheckBox x:Name="UI_Check_SideRebar" Content="Side Reinforcement" FontSize="12" FontWeight="SemiBold" Foreground="#4A759C" Margin="0,0,0,12" Click="toggle_visibility"/>

                    <StackPanel x:Name="UI_Group_SideRebar">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Rebar Type" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_SideType" Height="30" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Rows" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBox x:Name="UI_Text_SideRows" Text="2" Height="30" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Evenly Spaced Between Top And Bottom Bars On Both Faces. No Lap Splice — Stock Length Only." FontSize="10" Foreground="#999" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
