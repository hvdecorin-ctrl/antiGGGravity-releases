<UserControl x:Class="antiGGGravity.StructuralRebar.UI.Panels.BeamRebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <TextBlock Text="Beam Reinforcement" FontSize="18" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>

        <!-- STIRRUPS -->
        <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Stirrups / Ties" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Rebar Type" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_TransType" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Spacing (mm)" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox x:Name="UI_Text_TransSpacing" Text="200" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Offset (mm)" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox x:Name="UI_Text_TransStartOffset" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hook Start" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_HookStart" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hook End" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_HookEnd" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- TOP REINFORCEMENT -->
        <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Top Reinforcement" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>

                <!-- T1 -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox x:Name="UI_Check_T1" Content="T1 - Top Layer 1 (Outer)" FontSize="13" Foreground="#333" FontWeight="SemiBold" IsChecked="True" Margin="0,0,0,8" Click="toggle_visibility"/>
                        <StackPanel x:Name="UI_Group_T1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_T1Type" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Count" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_T1Count" Text="2" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- T2 -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel>
                        <CheckBox x:Name="UI_Check_T2" Content="T2 - Top Layer 2 (Inner)" FontSize="13" Foreground="#333" FontWeight="SemiBold" Margin="0,0,0,8" Click="toggle_visibility"/>
                        <StackPanel x:Name="UI_Group_T2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_T2Type" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Count" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_T2Count" Text="3" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hooks -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hook Start" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_TopHookStart" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hook End" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_TopHookEnd" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- BOTTOM REINFORCEMENT -->
        <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="15">
            <StackPanel>
                <TextBlock Text="Bottom Reinforcement" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>

                <!-- B1 -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox x:Name="UI_Check_B1" Content="B1 - Bottom Layer 1 (Outer)" FontSize="13" Foreground="#333" FontWeight="SemiBold" IsChecked="True" Margin="0,0,0,8" Click="toggle_visibility"/>
                        <StackPanel x:Name="UI_Group_B1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_B1Type" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Count" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_B1Count" Text="2" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- B2 -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel>
                        <CheckBox x:Name="UI_Check_B2" Content="B2 - Bottom Layer 2 (Inner)" FontSize="13" Foreground="#333" FontWeight="SemiBold" Margin="0,0,0,8" Click="toggle_visibility"/>
                        <StackPanel x:Name="UI_Group_B2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_B2Type" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Count" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_B2Count" Text="3" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hooks -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hook Start" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_BotHookStart" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hook End" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_BotHookEnd" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
