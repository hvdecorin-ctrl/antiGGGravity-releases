<Window x:Class="antiGGGravity.StructuralRebar.UI.ColumnRebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Column Reinforcement" 
        Height="800" Width="850" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="10"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
    </Window.Resources>

    <Border Style="{StaticResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Column Reinforcement" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Structural rebar for columns" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Click="UI_Button_Cancel_Click" Content="✕" Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Background="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,0,1,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Options" FontSize="11" FontWeight="SemiBold" Foreground="#888888" Margin="8,0,0,10"/>
                        <CheckBox x:Name="UI_Check_RemoveExisting" Content="Remove Existing" FontSize="13" Foreground="#555" Margin="8,0,0,15" IsChecked="True"/>
                        <CheckBox x:Name="UI_Check_CutRebar" Content="Lap Splices" FontSize="13" Foreground="#555" Margin="8,0,0,15" IsChecked="True"/>

                        <Separator Margin="5,15,5,10" Background="#E0E0E0"/>
                        
                        <TextBlock Text="Design Code" FontSize="11" FontWeight="SemiBold" Foreground="#888888" Margin="8,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_DesignCode" Margin="8,0,8,0" Height="28" SelectionChanged="DesignCode_Changed">
                            <ComboBoxItem Content="ACI 318" IsSelected="True"/>
                            <ComboBoxItem Content="AS 3600"/>
                            <ComboBoxItem Content="Eurocode 2"/>
                            <ComboBoxItem Content="NZS 3101"/>
                            <ComboBoxItem Content="Custom"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
                
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <ContentControl x:Name="UI_PanelHost" Margin="20"/>
                </ScrollViewer>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="#F9F9F9" Padding="25,12" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Close" Width="100" Height="36" Style="{StaticResource PremiumPrimaryButtonStyle}" Click="UI_Button_Cancel_Click" Margin="0,0,10,0" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="Generate" Width="140" Height="36" Style="{StaticResource PremiumPrimaryButtonStyle}" Click="UI_Button_Generate_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
