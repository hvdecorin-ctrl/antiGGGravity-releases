<Window x:Class="antiGGGravity.Views.Model.BracingParametersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bracing Parameters" Height="380" Width="450"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="UI_Title" Text="Structural Bracing" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            
            <TextBlock Text="Offset from Ends (mm):" Style="{StaticResource SectionLabelStyle}"/>
            <TextBox x:Name="UI_Text_Offset" Text="0" Style="{StaticResource FilterTextBoxStyle}" Margin="0,0,0,20"/>

            <StackPanel x:Name="UI_Panel_HFrame" Visibility="Collapsed">
                <TextBlock Text="Number of Braces:" Style="{StaticResource SectionLabelStyle}"/>
                <TextBox x:Name="UI_Text_Count" Text="3" Style="{StaticResource FilterTextBoxStyle}" Margin="0,0,0,20"/>
            </StackPanel>

            <TextBlock x:Name="UI_K_Instructions" Text="After clicking Generate, you will be prompted to select the Apex (V-point) element." 
                       FontStyle="Italic" Foreground="#636E72" FontSize="11" TextWrapping="Wrap" Visibility="Collapsed"/>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="{DynamicResource FooterPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Configure parameters" Style="{StaticResource StatusLabelStyle}"/>

                <Button Content="Cancel" Click="UI_Btn_Cancel_Click" Width="80" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2" Content="Generate" Click="UI_Btn_Generate_Click" Width="100" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
