<Window x:Class="antiGGGravity.Views.Model.BracingParametersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bracing Parameters" Height="380" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    
    <Border Style="{DynamicResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource CompanyLogoStyle}"/>
                        <TextBlock Style="{DynamicResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="UI_Title" Text="Structural Bracing" Style="{DynamicResource PremiumTitleStyle}"/>
                            <TextBlock Text="Configure parameters" Style="{DynamicResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{DynamicResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Btn_Cancel_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="25">
                
                <TextBlock Text="Offset from Ends (mm):" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,6"/>
                <TextBox x:Name="UI_Text_Offset" Text="0" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Margin="0,0,0,20"/>

                <StackPanel x:Name="UI_Panel_HFrame" Visibility="Collapsed">
                    <TextBlock Text="Number of Braces:" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,6"/>
                    <TextBox x:Name="UI_Text_Count" Text="3" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0" Margin="0,0,0,20"/>
                </StackPanel>

                <TextBlock x:Name="UI_K_Instructions" Text="After clicking Generate, you will be prompted to select the Apex (V-point) element." 
                           FontStyle="Italic" Foreground="#666666" FontSize="12" TextWrapping="Wrap" Visibility="Collapsed"/>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="20,15" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Ready" VerticalAlignment="Center" Foreground="#999999"/>

                    <Button Grid.Column="1" Content="Cancel" Click="UI_Btn_Cancel_Click" Width="80" Margin="0,0,12,0" Style="{DynamicResource PremiumPrimaryButtonStyle}"/>
                    <Button Grid.Column="2" Content="Generate" Click="UI_Btn_Generate_Click" Width="100" Style="{DynamicResource PremiumActionButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
