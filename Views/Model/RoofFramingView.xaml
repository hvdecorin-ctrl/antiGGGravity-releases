<Window x:Class="antiGGGravity.Views.Model.RoofFramingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roof Framing (Purlin &amp; Rafter)" 
        Height="800" Width="800"
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackgroundBrush}" ShowInTaskbar="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Purlin &amp; Rafter Generator" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- BODY -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="{DynamicResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LEFT PANEL: RAFTER -->
                <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Rafter (Along Slope)" Style="{StaticResource SectionLabelStyle}"/>

                        <TextBlock Text="Framing Type" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_RafterType" Height="28" Margin="0,0,0,12"/>

                        <TextBlock Text="Spacing (mm)" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="UI_Text_RafterSpacing" Text="600" Style="{StaticResource FilterTextBoxStyle}" Height="28" Margin="0,0,0,12"/>

                        <TextBlock Text="Start Offset (mm)" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="UI_Text_RafterOffset" Text="0" Style="{StaticResource FilterTextBoxStyle}" Height="28"/>
                    </StackPanel>
                </Border>

                <!-- RIGHT PANEL: PURLIN -->
                <Border Grid.Column="2" Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Purlin (Perpendicular)" Style="{StaticResource SectionLabelStyle}"/>

                        <TextBlock Text="Framing Type" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UI_Combo_PurlinType" Height="28" Margin="0,0,0,12"/>

                        <TextBlock Text="Spacing (mm)" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="UI_Text_PurlinSpacing" Text="400" Style="{StaticResource FilterTextBoxStyle}" Height="28" Margin="0,0,0,12"/>

                        <TextBlock Text="Start Offset (mm)" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="UI_Text_PurlinOffset" Text="0" Style="{StaticResource FilterTextBoxStyle}" Height="28"/>
                    </StackPanel>
                </Border>

                <!-- OPTIONS PANEL -->
                <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Placement Options" Style="{StaticResource SectionLabelStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Rafter &amp; Purlin Relationship" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,8"/>
                                <CheckBox x:Name="UI_Check_RafterUnder" Content="Rafter under bottom of purlin" IsChecked="True" FontSize="12" Margin="0,2"/>
                                <CheckBox x:Name="UI_Check_RotateSlope" Content="Rotate cross-section to slope" IsChecked="True" FontSize="12" Margin="0,12,0,2"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Generate Model" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,8"/>
                                <CheckBox x:Name="UI_Check_Purlins" Content="Generate purlins" IsChecked="True" FontSize="12" Margin="0,2"/>
                                <CheckBox x:Name="UI_Check_Rafters" Content="Generate rafters" IsChecked="True" FontSize="12" Margin="0,4"/>
                                
                                <StackPanel Margin="0,8,0,0">
                                    <CheckBox x:Name="UI_Check_EdgeRafters" Content="Ridge / Hip / Valley (2+ faces)" IsChecked="True" FontSize="12" Margin="0,2"/>
                                    <StackPanel Orientation="Horizontal" Margin="22,4,0,0">
                                        <TextBlock Text="Edge Beam Type" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="UI_Combo_EdgeType" Width="180" Height="24"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                            <CheckBox x:Name="UI_Check_FinishingOffset" Content="Offset for roof finishing layer" IsChecked="False" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="12"/>
                            <TextBox x:Name="UI_Text_FinishingOffset" Text="50" Style="{StaticResource FilterTextBoxStyle}" Width="60" Height="24"/>
                            <TextBlock Text="mm" FontSize="12" Foreground="{DynamicResource SubtitleBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UI_Status_Text" Text="Ready to generate • Pick a face first" Style="{StaticResource StatusLabelStyle}"/>
                
                <Button x:Name="UI_Button_Cancel" Grid.Column="1" Content="Cancel" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Button_Cancel_Click"/>
                <Button x:Name="UI_Button_Generate" Grid.Column="2" Content="Generate" Width="160" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Button_Generate_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
