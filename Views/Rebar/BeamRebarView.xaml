<Window x:Class="antiGGGravity.Views.Rebar.BeamRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beam Rebar" 
        Height="950" Width="900" 
        MinHeight="700" MinWidth="800"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="BEAM REBAR" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="{DynamicResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: TOP & BOTTOM REINFORCEMENT -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Top Reinforcement" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <!-- T1 Layer -->
                            <Border Background="#FAFAFA" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <CheckBox x:Name="UI_Check_T1" Content="T1 - Top Layer 1 (Outer)" FontSize="{DynamicResource StandardFontSize}" FontWeight="SemiBold" IsChecked="True" Margin="0,0,0,10" Click="toggle_visibility"/>
                                    <StackPanel x:Name="UI_Group_T1">
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="UI_Combo_T1Type" Height="28" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Count" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="UI_Text_T1Count" Text="2" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- T2 Layer -->
                            <Border Background="#FAFAFA" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <CheckBox x:Name="UI_Check_T2" Content="T2 - Top Layer 2 (Inner)" FontSize="{DynamicResource StandardFontSize}" FontWeight="SemiBold" IsChecked="True" Margin="0,0,0,10" Click="toggle_visibility"/>
                                    <StackPanel x:Name="UI_Group_T2">
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="UI_Combo_T2Type" Height="28" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Count" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="UI_Text_T2Count" Text="3" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Top Bars Hooks -->
                            <TextBlock Text="Hook Configuration" FontSize="{DynamicResource StandardFontSize}" FontWeight="SemiBold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_TopHookStart" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_TopHookEnd" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Bottom Reinforcement" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <!-- B2 Layer -->
                            <Border Background="#FAFAFA" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <CheckBox x:Name="UI_Check_B2" Content="B2 - Bottom Layer 2 (Inner)" FontSize="{DynamicResource StandardFontSize}" FontWeight="SemiBold" IsChecked="True" Margin="0,0,0,10" Click="toggle_visibility"/>
                                    <StackPanel x:Name="UI_Group_B2">
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="UI_Combo_B2Type" Height="28" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Count" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="UI_Text_B2Count" Text="3" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- B1 Layer -->
                            <Border Background="#FAFAFA" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <CheckBox x:Name="UI_Check_B1" Content="B1 - Bottom Layer 1 (Outer)" FontSize="{DynamicResource StandardFontSize}" FontWeight="SemiBold" IsChecked="True" Margin="0,0,0,10" Click="toggle_visibility"/>
                                    <StackPanel x:Name="UI_Group_B1">
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="UI_Combo_B1Type" Height="28" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Count" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="UI_Text_B1Count" Text="2" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Bottom Bars Hooks -->
                            <TextBlock Text="Hook Configuration" FontSize="{DynamicResource StandardFontSize}" FontWeight="SemiBold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_BotHookStart" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_BotHookEnd" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT COLUMN: Stirrups + Offsets -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Stirrups / Links" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <TextBlock Text="Rebar Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_TransShape" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_TransType" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Spacing (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_TransSpacing" Text="200" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HookStart" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HookEnd" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Rule Offsets" Style="{StaticResource SectionLabelStyle}"/>
                            <StackPanel>
                                <TextBlock Text="Stirrup Start Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="UI_Text_TransStartOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"/>
                            </StackPanel>
                            
                            <CheckBox x:Name="UI_Check_RemoveExisting" Content="Clear existing rebar" FontSize="{DynamicResource StandardFontSize}" IsChecked="True"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready to reinforce • Beam Rebar" Style="{StaticResource StatusLabelStyle}"/>

                <Button x:Name="UI_Button_Cancel" Grid.Column="1" Content="Cancel" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Button_Cancel_Click"/>
                <Button x:Name="UI_Button_Generate" Grid.Column="2" Content="Generate Rebar" Width="160" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Button_Generate_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
