<Window x:Class="antiGGGravity.Views.Rebar.RebarPaletteView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rebar Tools"
        Height="Auto" Width="Auto"
        MinWidth="285"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="0" 
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <Style TargetType="Button" x:Key="PaletteButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTipService.ShowDuration" Value="5000"/>
            <!-- Hover styling -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                 BorderBrush="{TemplateBinding BorderBrush}" 
                                 BorderThickness="1"
                                 CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5F3FF"/>
                                <Setter Property="BorderBrush" Value="#CCE8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CDE6F7"/>
                                <Setter Property="BorderBrush" Value="#99D1FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ButtonContentTemplate">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Image Source="{Binding IconPath}" Width="32" Height="32" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Text}" FontSize="10" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="70"/>
            </StackPanel>
        </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Background="White" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="15,0">
                    <!-- Company logo + tool name -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rebar Palette" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="General Rebar Tools" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30" Content="✕" 
                            Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="15,10,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 0: Selection label -->
                    <RowDefinition Height="Auto"/> <!-- 1: Selection row -->
                    <RowDefinition Height="Auto"/> <!-- 2: Visibility label -->
                    <RowDefinition Height="Auto"/> <!-- 3: Visibility row 1 -->
                    <RowDefinition Height="Auto"/> <!-- 4: Visibility row 2 -->
                    <RowDefinition Height="Auto"/> <!-- 5: Host label -->
                    <RowDefinition Height="Auto"/> <!-- 6: Host row (Grid) -->
                </Grid.RowDefinitions>

                <!-- Group: Selection & Reinforcement -->
                <TextBlock Text="Reinforcement &amp; Selection" FontSize="11" Foreground="#666" Margin="4,4,0,2" Grid.Row="0"/>
                <StackPanel Orientation="Vertical" Grid.Row="1" Margin="0,0,0,6">
                    <!-- Row 1 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <Button Style="{StaticResource PaletteButton}" Tag="QuickPick" Click="ToolButton_Click" ToolTip="Quick Pick Elements">
                            <StackPanel Orientation="Vertical">
                                <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/Pick(32x32).png" Width="32" Height="32"/>
                                <TextBlock Text="Quick Pick" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PaletteButton}" Tag="ColorSplasher" Click="ToolButton_Click" ToolTip="Visualize Values (Color Splasher)">
                            <StackPanel Orientation="Vertical">
                                <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/ColorSplasher(32x32).png" Width="32" Height="32"/>
                                <TextBlock Text="Splasher" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PaletteButton}" Tag="BeamRebar" Click="ToolButton_Click" ToolTip="Reinforce Beams">
                            <StackPanel Orientation="Vertical">
                                <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/RebarBeam(32x32).png" Width="32" Height="32"/>
                                <TextBlock Text="Beam Rebar" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <!-- Row 2 -->
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PaletteButton}" Tag="FoundationRebar" Click="ToolButton_Click" ToolTip="Reinforce Foundations">
                            <StackPanel Orientation="Vertical">
                                <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/RebarFoundation(32x32).png" Width="32" Height="32"/>
                                <TextBlock Text="Foundation" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PaletteButton}" Tag="WallRebar" Click="ToolButton_Click" ToolTip="Reinforce Walls">
                            <StackPanel Orientation="Vertical">
                                <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/RebarWall(32x32).png" Width="32" Height="32"/>
                                <TextBlock Text="Wall Rebar" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PaletteButton}" Tag="ColumnRebar" Click="ToolButton_Click" ToolTip="Reinforce Columns">
                            <StackPanel Orientation="Vertical">
                                <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/RebarColumn(32x32).png" Width="32" Height="32"/>
                                <TextBlock Text="Column Reo" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Group: Visibility & Basic Tools (Restoring 3-column layout) -->
                <TextBlock Text="Visibility &amp; Tools" FontSize="11" Foreground="#666" Margin="4,0,0,2" Grid.Row="2"/>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,2">
                    <Button Style="{StaticResource PaletteButton}" Tag="SetObscured" Click="ToolButton_Click" ToolTip="Set Obscured (Wireframe)">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/SetObscured(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Obscured" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PaletteButton}" Tag="SetUnobscured" Click="ToolButton_Click" ToolTip="Set Unobscured (Solid)">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/SetUnobscured(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Unobscured" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PaletteButton}" Tag="RebarCranked" Click="ToolButton_Click" ToolTip="Crank Rebar at Point">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/RebarCranked(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Crank Bar" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="0,0,0,6">
                    <Button Style="{StaticResource PaletteButton}" Tag="ShowRebar" Click="ToolButton_Click" ToolTip="Show All Rebar in View">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/ShowRebar(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Show All" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PaletteButton}" Tag="HideRebar" Click="ToolButton_Click" ToolTip="Hide All Rebar in View">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/HideRebar(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Hide All" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PaletteButton}" Tag="RebarSplit" Click="ToolButton_Click" ToolTip="Split Rebar at Point (Straight Lap)">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/RebarSplit(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Split Bar" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Group 3: Host Operations -->
                <TextBlock Text="Host &amp; Global Operations" FontSize="11" Foreground="#666" Margin="4,0,0,2" Grid.Row="5"/>
                <Grid Grid.Row="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1 -->
                    <Button Style="{StaticResource PaletteButton}" Tag="ShowByHost" Click="ToolButton_Click" ToolTip="Show Rebar for Selected Host" Grid.Row="0" Grid.Column="0">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/ShowRebarByHost(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Show Host" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PaletteButton}" Tag="HideByHost" Click="ToolButton_Click" ToolTip="Hide Rebar for Selected Host" Grid.Row="0" Grid.Column="1">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/HideRebarByHost(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Hide Host" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PaletteButton}" Tag="ShowByHostOnly" Click="ToolButton_Click" ToolTip="Isolate Rebar by Selected Host" Grid.Row="0" Grid.Column="2">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/ShowRebarByHostOnly(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Isolate Host" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Row 2 -->
                    <Button Style="{StaticResource PaletteButton}" Tag="SelectByHost" Click="ToolButton_Click" ToolTip="Select All Rebar in Selected Host" Grid.Row="1" Grid.Column="0">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/SelectRebar(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Select Host" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PaletteButton}" Tag="DeleteByHost" Click="ToolButton_Click" ToolTip="Delete All Rebar in Selected Host" Grid.Row="1" Grid.Column="1">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/antiGGGravity;component/Resources/Icons/SelectDeleteRebar(32x32).png" Width="32" Height="32"/>
                            <TextBlock Text="Delete Host" FontSize="10" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
