<Window x:Class="antiGGGravity.Views.Rebar.AssignElementNameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Element Name" Height="640" Width="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{DynamicResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource CompanyLogoStyle}"/>
                        <TextBlock Style="{DynamicResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Assign Element Name" Style="{DynamicResource PremiumTitleStyle}"/>
                            <TextBlock Text="Assign sequential Element Name to structural elements." Style="{DynamicResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{DynamicResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,15">
                <StackPanel>

                    <!-- CATEGORY FILTER -->
                    <TextBlock Text="Category" Style="{DynamicResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" Padding="15,12" Margin="0,0,0,15">
                        <ComboBox x:Name="UI_Combo_Category" FontSize="13" Height="30" VerticalContentAlignment="Center"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="All Categories"/>
                            <ComboBoxItem Content="Foundation" Tag="OST_StructuralFoundation"/>
                            <ComboBoxItem Content="Wall" Tag="OST_Walls"/>
                            <ComboBoxItem Content="Floor" Tag="OST_Floors"/>
                            <ComboBoxItem Content="Column" Tag="OST_StructuralColumns"/>
                            <ComboBoxItem Content="Beam" Tag="OST_StructuralFraming"/>
                            <ComboBoxItem Content="Roof" Tag="OST_Roofs"/>
                            <ComboBoxItem Content="Stair" Tag="OST_Stairs"/>
                            <ComboBoxItem Content="Generic Model" Tag="OST_GenericModel"/>
                            <ComboBoxItem Content="Door" Tag="OST_Doors"/>
                            <ComboBoxItem Content="Window" Tag="OST_Windows"/>
                            <ComboBoxItem Content="Room" Tag="OST_Rooms"/>
                        </ComboBox>
                    </Border>

                    <!-- NAMING MODE -->
                    <TextBlock Text="Naming Mode" Style="{DynamicResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" Padding="15,12" Margin="0,0,0,15">
                        <StackPanel>
                            <!-- Prefix Source Dropdown -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="Prefix Source:" VerticalAlignment="Center" Foreground="#555" FontSize="12" Margin="0,0,8,0" Width="80"/>
                                <ComboBox x:Name="UI_Combo_PrefixSource" FontSize="13" Height="30" Width="180" VerticalContentAlignment="Center" SelectedIndex="0">
                                    <ComboBoxItem Content="Type Mark" Tag="TypeMark"/>
                                    <ComboBoxItem Content="Type Comments" Tag="TypeComments"/>
                                    <ComboBoxItem Content="Type Name" Tag="TypeName"/>
                                </ComboBox>
                            </StackPanel>

                            <RadioButton x:Name="UI_Radio_TypeMark" Content="Prefix + Number  (e.g. SF1-1, B1-2)" 
                                         IsChecked="True" FontSize="13" Foreground="#333" Margin="0,0,0,10"
                                         Checked="UI_NamingMode_Changed"/>
                            <RadioButton x:Name="UI_Radio_TypeMarkXY" Content="Prefix + X/Y + Number  (e.g. B1-X1, B1-Y1)" 
                                         FontSize="13" Foreground="#333" Margin="0,0,0,10"
                                         Checked="UI_NamingMode_Changed"/>
                            <RadioButton x:Name="UI_Radio_CopyExact" Content="Copy Exact from Source  (no numbering)" 
                                         FontSize="13" Foreground="#333" Margin="0,0,0,10"
                                         Checked="UI_NamingMode_Changed"/>
                            <RadioButton x:Name="UI_Radio_CustomName" Content="Custom Name + Number" 
                                         FontSize="13" Foreground="#333"
                                         Checked="UI_NamingMode_Changed"/>
                            <Border x:Name="UI_CustomName_Panel" Visibility="Collapsed" Margin="24,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Prefix:" VerticalAlignment="Center" Foreground="#555" FontSize="12" Margin="0,0,8,0"/>
                                    <TextBox x:Name="UI_TextBox_CustomName" Width="160" Height="30" FontSize="13" 
                                             Padding="8,4" VerticalContentAlignment="Center"
                                             BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1"/>
                                    <TextBlock Text=" - 1, 2, 3..." VerticalAlignment="Center" Foreground="#999" FontSize="12" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- NUMBERING RULE -->
                    <TextBlock x:Name="UI_NumberingRule_Label" Text="Numbering Rule" Style="{DynamicResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    <Border x:Name="UI_NumberingRule_Panel" Background="#FAFAFA" CornerRadius="8" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" Padding="15,12" Margin="0,0,0,15">
                        <StackPanel>
                            <RadioButton x:Name="UI_Radio_Auto" Content="Auto (Left → Right sorting)" 
                                         IsChecked="True" FontSize="13" Foreground="#333" Margin="0,0,0,10"/>
                            <RadioButton x:Name="UI_Radio_Manual" Content="Manual (Click elements to number 1, 2, 3...)" 
                                         FontSize="13" Foreground="#333"/>
                        </StackPanel>
                    </Border>

                    <!-- SCOPE -->
                    <TextBlock Text="Scope" Style="{DynamicResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" Padding="15,12" Margin="0,0,0,0">
                        <StackPanel>
                            <RadioButton x:Name="UI_Radio_ActiveView" Content="Active View" 
                                         IsChecked="True" FontSize="13" Foreground="#333" Margin="0,0,0,10"/>
                            <RadioButton x:Name="UI_Radio_EntireProject" Content="Entire Project" 
                                         FontSize="13" Foreground="#333"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="20,15" Background="#FAFAFA" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UI_Status_Text" Text="Configure options and assign." VerticalAlignment="Center" Foreground="#999999"/>
                    <Button Grid.Column="1" Content="Cancel" Width="90" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,12,0" Click="UI_Close_Click"/>
                    <Button Grid.Column="2" Content="Assign" Width="120" Style="{DynamicResource PremiumActionButtonStyle}" Click="UI_Assign_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
