<Window x:Class="antiGGGravity.Views.Rebar.StripFootingRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Strip Footing Rebar" 
        Height="800" Width="800" 
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="STRIP FOOTING REBAR" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="{DynamicResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Top Reinforcement" Style="{StaticResource SectionLabelStyle}"/>
                            <CheckBox x:Name="UI_Check_TopBars" Content="Enable Top Bars" FontSize="{DynamicResource StandardFontSize}" IsChecked="True" Margin="0,0,0,12" Click="UI_Check_TopBars_Click"/>
                            
                            <StackPanel x:Name="UI_Group_Top">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_TopType" Height="28" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Count" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_TopCount" Text="4" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock Text="Hook Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_TopHookStart" Height="28" VerticalContentAlignment="Center"/>
                                <ComboBox x:Name="UI_Combo_TopHookEnd" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Bottom Reinforcement" Style="{StaticResource SectionLabelStyle}"/>
                            <CheckBox x:Name="UI_Check_BottomBars" Content="Enable Bottom Bars" FontSize="{DynamicResource StandardFontSize}" IsChecked="True" Margin="0,0,0,12" Click="UI_Check_BottomBars_Click"/>
                            
                            <StackPanel x:Name="UI_Group_Bottom">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_BottomType" Height="28" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Count" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_BottomCount" Text="4" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock Text="Hook Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_BotHookStart" Height="28" VerticalContentAlignment="Center"/>
                                <ComboBox x:Name="UI_Combo_BotHookEnd" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Longitudinal Rule Offsets" Style="{StaticResource SectionLabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Start Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_LongStartOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="End Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_LongEndOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT COLUMN -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Stirrups / Links" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <TextBlock Text="Rebar Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_TransShape" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_TransType" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Spacing (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_TransSpacing" Text="200" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HookStart" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HookEnd" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Stirrup Rule Offsets" FontSize="{DynamicResource StandardFontSize}" FontWeight="Bold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <StackPanel>
                                <TextBlock Text="Start Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="UI_Text_TransStartOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"/>
                            </StackPanel>
                            
                            <CheckBox x:Name="UI_Check_RemoveExisting" Content="Clear existing rebar" FontSize="{DynamicResource StandardFontSize}" IsChecked="True" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready to reinforce • Strip Footing Rebar" Style="{StaticResource StatusLabelStyle}"/>

                <Button x:Name="UI_Button_Cancel" Grid.Column="1" Content="Cancel" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Button_Cancel_Click"/>
                <Button x:Name="UI_Button_Generate" Grid.Column="2" Content="Generate Rebar" Width="160" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Button_Generate_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
