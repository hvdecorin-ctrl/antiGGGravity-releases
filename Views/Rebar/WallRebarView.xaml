<Window x:Class="antiGGGravity.Views.Rebar.WallRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wall Rebar" 
        Height="800" Width="800" 
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="WALL REBAR" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT (DUAL PANEL) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="{DynamicResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: Vertical Reinforcement -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Vertical Reinforcement" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_VertType" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Spacing (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_VertSpacing" Text="200" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>
                            
                            <TextBlock Text="Rule Offsets" FontSize="{DynamicResource StandardFontSize}" FontWeight="Bold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Start Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_VertStartOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="End Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_VertEndOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Hooks &amp; Extensions" FontSize="{DynamicResource StandardFontSize}" FontWeight="Bold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Bottom" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_VertHookStart" Height="28" VerticalContentAlignment="Center"/>
                                    <CheckBox x:Name="UI_Check_VertHookStartOut" Content="Bend Outward" FontSize="{DynamicResource StandardFontSize}" Margin="0,5,0,10"/>
                                    
                                    <CheckBox x:Name="UI_Check_VertBotExt" Content="Bottom Ext (mm)" FontSize="{DynamicResource StandardFontSize}" IsChecked="False" Margin="0,0,0,5" Click="UI_Check_VertBotExt_Click"/>
                                    <TextBox x:Name="UI_Text_VertBotExt" Text="500" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Visibility="Collapsed"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook Top" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_VertHookEnd" Height="28" VerticalContentAlignment="Center"/>
                                    <CheckBox x:Name="UI_Check_VertHookEndOut" Content="Bend Outward" FontSize="{DynamicResource StandardFontSize}" Margin="0,5,0,10"/>
                                    
                                    <CheckBox x:Name="UI_Check_VertTopExt" Content="Top Ext (mm)" FontSize="{DynamicResource StandardFontSize}" IsChecked="False" Margin="0,0,0,5" Click="UI_Check_VertTopExt_Click"/>
                                    <TextBox x:Name="UI_Text_VertTopExt" Text="500" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT COLUMN: Horizontal Reinforcement -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Horizontal Reinforcement" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HorizType" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Spacing (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_HorizSpacing" Text="200" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>
                            
                            <TextBlock Text="Rule Offsets" FontSize="{DynamicResource StandardFontSize}" FontWeight="Bold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Top Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_HorizTopOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Bottom Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_HorizBottomOffset" Text="50" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Hooks Configuration" FontSize="{DynamicResource StandardFontSize}" FontWeight="Bold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HorizHookStart" Height="28" VerticalContentAlignment="Center"/>
                                    <CheckBox x:Name="UI_Check_HorizHookStartOut" Content="Bend Outward" FontSize="{DynamicResource StandardFontSize}" Margin="0,5,0,10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HorizHookEnd" Height="28" VerticalContentAlignment="Center"/>
                                    <CheckBox x:Name="UI_Check_HorizHookEndOut" Content="Bend Outward" FontSize="{DynamicResource StandardFontSize}" Margin="0,5,0,10"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Placement Config" FontSize="{DynamicResource StandardFontSize}" FontWeight="Bold" Foreground="{DynamicResource SubtitleBrush}" Margin="0,5,0,8"/>
                            <TextBlock Text="Layer Layout" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_LayerConfig" Height="28" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Centre" IsSelected="True"/>
                                <ComboBoxItem Content="Both faces"/>
                                <ComboBoxItem Content="Internal face"/>
                                <ComboBoxItem Content="External face"/>
                            </ComboBox>
                            <CheckBox x:Name="UI_Check_RemoveExisting" Content="Clear existing rebar" FontSize="{DynamicResource StandardFontSize}" IsChecked="True" Margin="0,15,0,5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready to reinforce • Wall Rebar" Style="{StaticResource StatusLabelStyle}"/>

                <Button x:Name="UI_Button_Cancel" Grid.Column="1" Content="Cancel" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Button_Cancel_Click"/>
                <Button x:Name="UI_Button_Generate" Grid.Column="2" Content="Generate Rebar" Width="160" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Button_Generate_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
