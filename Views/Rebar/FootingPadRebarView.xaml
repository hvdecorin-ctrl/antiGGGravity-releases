<Window x:Class="antiGGGravity.Views.Rebar.FootingPadRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Footing Pad Rebar" 
        Height="800" Width="800"
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="FOOTING PAD REBAR" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT (Dual Panel) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="{DynamicResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: TOP REINFORCEMENT -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <CheckBox x:Name="UI_Check_TopBars" IsChecked="True" Margin="0,0,0,12" Click="UI_Check_TopBars_Click">
                                <TextBlock Text="Top Reinforcement" Style="{StaticResource SectionLabelStyle}" Margin="5,0,0,0"/>
                            </CheckBox>
                            
                            <StackPanel x:Name="UI_Group_Top">
                                <TextBlock Text="Rebar Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_TopShape" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_TopType" Height="28" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Spacing (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_TopSpacing" Text="200" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Bar Hook (Ends)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_TopHook" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT COLUMN: BOTTOM REINFORCEMENT -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <CheckBox x:Name="UI_Check_BottomBars" IsChecked="True" Margin="0,0,0,12" Click="UI_Check_BottomBars_Click">
                                <TextBlock Text="Bottom Reinforcement" Style="{StaticResource SectionLabelStyle}" Margin="5,0,0,0"/>
                            </CheckBox>
                            
                            <StackPanel x:Name="UI_Group_Bottom">
                                <TextBlock Text="Rebar Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_BottomShape" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_BottomType" Height="28" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Spacing (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_BottomSpacing" Text="200" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Bar Hook (Ends)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_BottomHook" Height="28" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            
                            <CheckBox x:Name="UI_Check_RemoveExisting" Content="Remove Existing Rebar" VerticalAlignment="Center" FontWeight="SemiBold" IsChecked="True" FontSize="{DynamicResource StandardFontSize}" Margin="0,15,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready to reinforce • Footing Pad Rebar" Style="{StaticResource StatusLabelStyle}"/>

                <Button x:Name="UI_Button_Cancel" Grid.Column="1" Content="Cancel" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Button_Cancel_Click"/>
                <Button x:Name="UI_Button_Generate" Grid.Column="2" Content="Generate Rebar" Width="160" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Button_Generate_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
