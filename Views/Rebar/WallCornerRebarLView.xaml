<Window x:Class="antiGGGravity.Views.Rebar.WallCornerRebarLView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wall Corner Rebar L-Shape Generator" 
        Height="700" Width="850" 
        MinHeight="600" MinWidth="750"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="70" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border Style="{StaticResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Wall Corner Rebar L-Shape" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Generate L-Shape reinforcement for wall corners" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Button_Cancel_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- MAIN CONTENT (DUAL PANEL) -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: L-Shape Bar Settings -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="L-Shape Corner Bars" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,15"/>
                                
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rebar Type" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_HorizType" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Spacing (mm)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_HorizSpacing" Text="200" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock Text="Leg Lengths (mm)" FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Leg 1 (Wall 1)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_HorizLeg1" Text="1000" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Leg 2 (Wall 2)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_HorizLeg2" Text="1000" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Rule Offsets" FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Top Offset (mm)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_HorizTopOffset" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Bottom Offset (mm)" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="UI_Text_HorizBottomOffset" Text="50" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Hooks Configuration" FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Hook Start" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_HorizHookStart" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="UI_Check_HorizHookStartOut" Content="Bend Outward" FontSize="13" Foreground="#666666" Margin="0,0,0,10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Hook End" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="UI_Combo_HorizHookEnd" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="UI_Check_HorizHookEndOut" Content="Bend Outward" FontSize="13" Foreground="#666666" Margin="0,0,0,10"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- RIGHT PANEL: Trimmer Bars & Placement Config -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Trimmer Bars Section -->
                        <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Trimmer Bars" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,15"/>
                                
                                <CheckBox x:Name="UI_Check_AddTrimmers" Content="Add Trimmer Bars at Corner" 
                                          FontSize="13" 
                                          FontWeight="SemiBold"
                                          Foreground="#333333"
                                          IsChecked="True" 
                                          Margin="0,0,0,15"/>
                                
                                <StackPanel x:Name="TrimmerOptions">
                                    <TextBlock Text="Trimmer Rebar Type" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_TrimmerType" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,10"/>
                                    
                                    <TextBlock Text="Trimmer bars are placed vertical at the corner and at the L-bar bend points." 
                                               FontSize="11" Foreground="#999999" FontStyle="Italic" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Placement Config Section -->
                        <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Placement Config" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,15"/>
                                <TextBlock Text="Layer Layout" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                <ComboBox x:Name="UI_Combo_LayerConfig" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" Margin="0,0,0,15">
                                    <ComboBoxItem Content="Centre" IsSelected="True"/>
                                    <ComboBoxItem Content="Both faces"/>
                                    <ComboBoxItem Content="Internal face"/>
                                    <ComboBoxItem Content="External face"/>
                                </ComboBox>
                                <CheckBox x:Name="UI_Check_RemoveExisting" Content="Clear existing rebar" FontSize="13" Foreground="#666666" IsChecked="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="20,15" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Ready to reinforce • Wall Corner Rebar L-Shape" VerticalAlignment="Center" Foreground="#999999"/>

                    <Button x:Name="UI_Button_Cancel" Grid.Column="1" Content="Cancel" Width="90" Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,0,12,0" Click="UI_Button_Cancel_Click"/>
                    <Button x:Name="UI_Button_Generate" Grid.Column="2" Content="Generate" Width="140" Style="{StaticResource PremiumActionButtonStyle}" Click="UI_Button_Generate_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
