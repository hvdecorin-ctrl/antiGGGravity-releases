<Window x:Class="antiGGGravity.Views.Rebar.ColumnRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Column Rebar" 
        Height="800" Width="800"
        MinHeight="600" MinWidth="750"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="COLUMN REBAR" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="{DynamicResource ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: VERTICAL MAIN BARS -->
                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Vertical Main Bars" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VerticalType" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                            <TextBlock Text="Rebar Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_VerticalShape" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Bottom Hook" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_VHookBot" Height="28" VerticalContentAlignment="Center"/>
                                    <CheckBox x:Name="UI_Check_VHookBotOut" Content="Bend Outward" IsChecked="True" FontSize="{DynamicResource StandardFontSize}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Top Hook" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_VHookTop" Height="28" VerticalContentAlignment="Center"/>
                                    <CheckBox x:Name="UI_Check_VHookTopOut" Content="Bend Outward" IsChecked="False" FontSize="{DynamicResource StandardFontSize}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Bars in X-Dir (Face)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_CountX" Text="3" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Bars in Y-Dir (Face)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_CountY" Text="3" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox x:Name="UI_Check_TopExt" IsChecked="False" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Top Extension (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}"/>
                                    </StackPanel>
                                    <TextBox x:Name="UI_Text_TopExtValue" Text="250" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox x:Name="UI_Check_BotExt" IsChecked="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Bottom Extension (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}"/>
                                    </StackPanel>
                                    <TextBox x:Name="UI_Text_BotExtValue" Text="250" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT COLUMN: TIES / STIRRUPS -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Ties / Stirrups" Style="{StaticResource SectionLabelStyle}"/>
                            
                            <TextBlock Text="Rebar Type" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_TieType" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                            <TextBlock Text="Rebar Shape" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="UI_Combo_TieShape" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hook Start" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HookStart" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hook End" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="UI_Combo_HookEnd" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Spacing (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="UI_Text_TieSpacing" Text="200" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Bot Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_TieBotOffset" Text="80" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Top Offset (mm)" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UI_Text_TieTopOffset" Text="80" Height="28" VerticalContentAlignment="Center" Padding="8,0" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="UI_Check_RemoveExisting" Content="Remove Existing Rebar" VerticalAlignment="Center" IsChecked="True" FontSize="{DynamicResource StandardFontSize}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready to reinforce • Column Rebar" Style="{StaticResource StatusLabelStyle}"/>

                <Button x:Name="UI_Button_Cancel" Grid.Column="1" Content="Cancel" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Button_Cancel_Click"/>
                <Button x:Name="UI_Button_Generate" Grid.Column="2" Content="Generate Rebar" Width="160" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Button_Generate_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
