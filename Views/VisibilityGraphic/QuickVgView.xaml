<Window x:Class="antiGGGravity.Views.VisibilityGraphic.QuickVgView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quick VG" Height="800" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        MinHeight="400" MinWidth="340" Topmost="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <DataTemplate x:Key="CategoryItemTemplate">
                <Grid Margin="5,4" Background="Transparent" ToolTip="Click checkbox to toggle visibility. Click text or row to select item.">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>
            
            <Style x:Key="CategoryItemContainerStyle" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#E6F2FA"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F5F5F5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <ControlTemplate x:Key="CircularButtonTemplate" TargetType="Button">
                <Grid>
                    <Ellipse x:Name="BackgroundEllipse" Fill="White" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="2.5"/>
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BackgroundEllipse" Property="Fill" Value="#F0F0F0"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="BackgroundEllipse" Property="Fill" Value="#E0E0E0"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" 
                      ResizeBorderThickness="10" 
                      GlassFrameThickness="0" 
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    
    <Border BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" Background="White" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <!-- Company logo + tool name -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock Style="{DynamicResource CompanyLogoStyle}"/>
                        <TextBlock Style="{DynamicResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Quick VG" Style="{DynamicResource PremiumTitleStyle}"/>
                            <TextBlock Text="Category Visibility Manager" Style="{DynamicResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Style="{DynamicResource PremiumIconButtonStyle}" Width="30" Height="30" Content="✕" 
                            Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Structural Column -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header (0) -->
                        <RowDefinition Height="Auto"/> <!-- Custom Slots (1) -->
                        <RowDefinition Height="Auto"/> <!-- Search (2) -->
                        <RowDefinition Height="Auto"/> <!-- CheckBox (3) -->
                        <RowDefinition Height="*"/>    <!-- List (4) -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Custom Parameter" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    
                    <!-- Custom Buttons -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnCustomA" Grid.Column="0" Content="Custom A" Click="BtnCustomA_Click" Tag="Active"
                                Height="26" FontSize="12" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0,0,0,2"
                                Background="Transparent" Foreground="#333" BorderBrush="#008855"/>
                        <Button x:Name="BtnCustomB" Grid.Column="2" Content="Custom B" Click="BtnCustomB_Click" Tag="Inactive"
                                Height="26" FontSize="12" FontWeight="Normal" Cursor="Hand" BorderThickness="0,0,0,2"
                                Background="Transparent" Foreground="#999" BorderBrush="Transparent"/>
                        <Button x:Name="BtnCustomC" Grid.Column="4" Content="Custom C" Click="BtnCustomC_Click" Tag="Inactive"
                                Height="26" FontSize="12" FontWeight="Normal" Cursor="Hand" BorderThickness="0,0,0,2"
                                Background="Transparent" Foreground="#999" BorderBrush="Transparent"/>
                    </Grid>
                    
                    <Border Grid.Row="2" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Background="White">
                        <Grid>
                            <TextBlock Text="Search Custom..." Foreground="#A0A0A0" Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=StructSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=StructSearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="StructSearchBox" Padding="8" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" TextChanged="StructSearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                    
                    <Grid Grid.Row="3" Margin="5,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="StructSelectAllCheckBox" VerticalAlignment="Center"
                                  Checked="StructSelectAllCheckBox_Checked" 
                                  Unchecked="StructSelectAllCheckBox_Unchecked"/>
                        <TextBlock Grid.Column="1" Text="Select" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <ListBox x:Name="StructListBox" Grid.Row="4" BorderThickness="0" Background="Transparent" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionMode="Extended"
                             MouseDoubleClick="StructListBox_MouseDoubleClick"
                             ItemTemplate="{StaticResource CategoryItemTemplate}"
                             ItemContainerStyle="{StaticResource CategoryItemContainerStyle}"/>
                </Grid>

                <!-- Vertical Divider and Buttons -->
                <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="BtnAdd" Grid.Row="0" Width="32" Height="32" Margin="0,0,0,10" 
                            ToolTip="Add to Custom Parameter" Click="BtnAdd_Click" 
                            BorderBrush="#008855" Background="Transparent" Template="{StaticResource CircularButtonTemplate}">
                        <Path Data="M 12 4 L 12 20 M 4 12 L 20 12" Stroke="#008855" StrokeThickness="3" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="BtnRemove" Grid.Row="1" Width="32" Height="32" 
                            ToolTip="Remove from Custom Parameter" Click="BtnRemove_Click" 
                            BorderBrush="#FF5500" Background="Transparent" Template="{StaticResource CircularButtonTemplate}">
                        <Path Data="M 4 12 L 20 12" Stroke="#FF5500" StrokeThickness="3" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- Coordinate Column -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Filter list -->
                        <RowDefinition Height="Auto"/> <!-- Search -->
                        <RowDefinition Height="Auto"/> <!-- CheckBox -->
                        <RowDefinition Height="*"/>    <!-- List -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="All Categories" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    
                    <!-- Discipline Filter -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Filter List:" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="DisciplineFilterCombo" Grid.Column="1" 
                                  SelectedIndex="0" SelectionChanged="DisciplineFilterCombo_SelectionChanged"
                                  Height="26" FontSize="12" Padding="6,3" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="All"/>
                            <ComboBoxItem Content="Architecture"/>
                            <ComboBoxItem Content="Structure"/>
                            <ComboBoxItem Content="Mechanical"/>
                            <ComboBoxItem Content="Electrical"/>
                            <ComboBoxItem Content="Piping"/>
                            <ComboBoxItem Content="Infrastructure"/>
                            <ComboBoxItem Content="Annotation"/>
                            <ComboBoxItem Content="Links"/>
                        </ComboBox>
                    </Grid>
                    
                    <Border Grid.Row="2" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Background="White">
                        <Grid>
                            <TextBlock Text="Search Categories..." Foreground="#A0A0A0" Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=CoordSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=CoordSearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="CoordSearchBox" Padding="8" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" TextChanged="CoordSearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                    
                    <Grid Grid.Row="3" Margin="5,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="CoordSelectAllCheckBox" VerticalAlignment="Center"
                                  Checked="CoordSelectAllCheckBox_Checked" 
                                  Unchecked="CoordSelectAllCheckBox_Unchecked"/>
                        <TextBlock Grid.Column="1" Text="Select" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <ListBox x:Name="CoordListBox" Grid.Row="4" BorderThickness="0" Background="Transparent" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionMode="Extended"
                             MouseDoubleClick="CoordListBox_MouseDoubleClick"
                             ItemTemplate="{StaticResource CategoryItemTemplate}"
                             ItemContainerStyle="{StaticResource CategoryItemContainerStyle}"/>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="20,15" Background="#FAFAFA" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Apply" Click="Apply_Click" Style="{DynamicResource PremiumActionButtonStyle}" Width="85" Height="32" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
