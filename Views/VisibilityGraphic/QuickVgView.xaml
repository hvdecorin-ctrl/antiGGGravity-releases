<Window x:Class="antiGGGravity.Views.VisibilityGraphic.QuickVgView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quick VG" Height="500" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        MinHeight="400" MinWidth="340" Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="70" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="0" 
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <DataTemplate x:Key="CategoryItemTemplate">
                <Grid Margin="5,4" Background="Transparent" ToolTip="Click checkbox to toggle visibility. Click text or row to select item.">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>
            
            <Style x:Key="CategoryItemContainerStyle" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#E6F2FA"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F5F5F5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Background="White" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <!-- Company logo + tool name -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Quick VG" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Category Visibility Manager" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30" Content="✕" 
                            Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Structural Column -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Search -->
                        <RowDefinition Height="Auto"/> <!-- CheckBox -->
                        <RowDefinition Height="*"/>    <!-- List -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Custom Parameter" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    
                    <Border Grid.Row="1" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Background="White">
                        <Grid>
                            <TextBlock Text="Search Custom..." Foreground="#A0A0A0" Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=StructSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=StructSearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="StructSearchBox" Padding="8" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" TextChanged="StructSearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                    
                    <CheckBox x:Name="StructSelectAllCheckBox" Grid.Row="2" Content="Select All / None" 
                              Checked="StructSelectAllCheckBox_Checked" 
                              Unchecked="StructSelectAllCheckBox_Unchecked" 
                              VerticalContentAlignment="Center" Margin="5,0,0,10"/>
                    
                    <ListBox x:Name="StructListBox" Grid.Row="3" BorderThickness="0" Background="Transparent" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionMode="Extended"
                             MouseDoubleClick="StructListBox_MouseDoubleClick"
                             ItemTemplate="{StaticResource CategoryItemTemplate}"
                             ItemContainerStyle="{StaticResource CategoryItemContainerStyle}"/>
                </Grid>

                <!-- Vertical Divider and Buttons -->
                <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="BtnAdd" Grid.Row="0" Width="32" Height="32" Margin="0,0,0,10" 
                            ToolTip="Add to Custom Parameter" Click="BtnAdd_Click" Style="{StaticResource PremiumActionButtonStyle}">
                        <Path Data="M 12 4 L 12 20 M 4 12 L 20 12" Stroke="#333333" StrokeThickness="2.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="BtnRemove" Grid.Row="1" Width="32" Height="32" 
                            ToolTip="Remove from Custom Parameter" Click="BtnRemove_Click" Style="{StaticResource PremiumActionButtonStyle}">
                        <Path Data="M 4 12 L 20 12" Stroke="#333333" StrokeThickness="2.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- Coordinate Column -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Search -->
                        <RowDefinition Height="Auto"/> <!-- CheckBox -->
                        <RowDefinition Height="*"/>    <!-- List -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="All Categories" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,10"/>
                    
                    <Border Grid.Row="1" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Background="White">
                        <Grid>
                            <TextBlock Text="Search Categories..." Foreground="#A0A0A0" Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=CoordSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=CoordSearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="CoordSearchBox" Padding="8" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" TextChanged="CoordSearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                    
                    <CheckBox x:Name="CoordSelectAllCheckBox" Grid.Row="2" Content="Select All / None" 
                              Checked="CoordSelectAllCheckBox_Checked" 
                              Unchecked="CoordSelectAllCheckBox_Unchecked" 
                              VerticalContentAlignment="Center" Margin="5,0,0,10"/>
                    
                    <ListBox x:Name="CoordListBox" Grid.Row="3" BorderThickness="0" Background="Transparent" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionMode="Extended"
                             MouseDoubleClick="CoordListBox_MouseDoubleClick"
                             ItemTemplate="{StaticResource CategoryItemTemplate}"
                             ItemContainerStyle="{StaticResource CategoryItemContainerStyle}"/>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="20,15" Background="#FAFAFA" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Apply" Click="Apply_Click" Style="{StaticResource PremiumActionButtonStyle}" Width="85" Height="32" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
