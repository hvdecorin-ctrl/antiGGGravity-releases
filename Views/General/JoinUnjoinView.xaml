<Window x:Class="antiGGGravity.Views.General.JoinUnjoinView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Join &amp; Unjoin Advance" Height="600" Width="800"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="CanResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="JOIN &amp; UNJOIN ADVANCE" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- OPTIONS -->
        <Border Grid.Row="1" Margin="25,15,25,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Operation:" FontWeight="SemiBold" Foreground="{DynamicResource SubtitleBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <RadioButton x:Name="UI_Radio_Join" Content="Join" IsChecked="True" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <RadioButton x:Name="UI_Radio_Unjoin" Content="Unjoin" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- DUAL PANEL -->
        <Grid Grid.Row="2" Margin="{DynamicResource ContentMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: PRIORITY -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}" Padding="15,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="✂️ Priority (Cutting Elements)" Style="{StaticResource SectionLabelStyle}" Margin="0"/>
                    </Border>
                    <ListBox x:Name="UI_List_Left" Grid.Row="1" BorderThickness="0" Background="Transparent" Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Padding="8,4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Border Grid.Row="2" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <UniformGrid Columns="2">
                            <Button Content="All" Click="UI_Btn_LeftAll_Click" Height="28" Margin="4" Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button Content="None" Click="UI_Btn_LeftNone_Click" Height="28" Margin="4" Style="{StaticResource SecondaryButtonStyle}"/>
                        </UniformGrid>
                    </Border>
                </Grid>
            </Border>

            <!-- ARROW -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="▶" HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource PrimaryBlueBrush}"/>
            </StackPanel>

            <!-- RIGHT: SECONDARY -->
            <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}" Padding="0">
                 <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}" Padding="15,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="🧱 Secondary (To Be Joined)" Style="{StaticResource SectionLabelStyle}" Margin="0"/>
                    </Border>
                    <ListBox x:Name="UI_List_Right" Grid.Row="1" BorderThickness="0" Background="Transparent" Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Padding="8,4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Border Grid.Row="2" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <UniformGrid Columns="2">
                            <Button Content="All" Click="UI_Btn_RightAll_Click" Height="28" Margin="4" Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button Content="None" Click="UI_Btn_RightNone_Click" Height="28" Margin="4" Style="{StaticResource SecondaryButtonStyle}"/>
                        </UniformGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="3" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="UI_Status_Text" Grid.Column="0" Text="Select categories and process." Style="{StaticResource StatusLabelStyle}"/>

                <Button x:Name="UI_Btn_Cancel" Grid.Column="1" Content="Cancel" Width="90" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Btn_Cancel_Click"/>
                <Button x:Name="UI_Btn_Run" Grid.Column="2" Content="Process" Width="120" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Btn_Run_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
