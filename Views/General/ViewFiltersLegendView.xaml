<Window x:Class="antiGGGravity.Views.General.ViewFiltersLegendView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Filters Legend" Height="800" Width="600"
        MinWidth="500" MinHeight="450"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="FILTERS LEGEND" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="{DynamicResource ContentMargin}">
             <Grid.ColumnDefinitions>
                 <ColumnDefinition Width="220"/>
                 <ColumnDefinition Width="20"/>
                 <ColumnDefinition Width="*"/>
             </Grid.ColumnDefinitions>
             
             <!-- LEFT: SETTINGS -->
             <Border Grid.Column="0" Style="{StaticResource SectionBorderStyle}" Padding="15">
                 <StackPanel>
                     <TextBlock Text="Settings" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,10"/>
                     
                     <!-- Text Style -->
                     <TextBlock Text="Text Style" Foreground="{StaticResource SubtitleBrush}" Margin="0,0,0,5"/>
                     <ComboBox x:Name="UI_Combo_TextStyle" Height="28" Margin="0,0,0,15"/>
                     
                     <!-- Colour Source -->
                     <TextBlock Text="Colour Source" Foreground="{StaticResource SubtitleBrush}" Margin="0,0,0,5"/>
                     <ComboBox x:Name="UI_Combo_ColourSource" Height="28" Margin="0,0,0,15" SelectedIndex="0" SelectionChanged="UI_Combo_ColourSource_SelectionChanged">
                         <ComboBoxItem Content="Projection"/>
                         <ComboBoxItem Content="Cut"/>
                     </ComboBox>
                     
                     <Separator Margin="0,5,0,15"/>
                     
                     <!-- Dimensions -->
                     <TextBlock Text="Box Dimensions (mm)" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,10"/>
                     
                     <Grid Margin="0,0,0,10">
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="10"/>
                             <ColumnDefinition Width="*"/>
                         </Grid.ColumnDefinitions>
                         <StackPanel Grid.Column="0">
                             <TextBlock Text="Width" Foreground="{StaticResource SubtitleBrush}"/>
                             <TextBox x:Name="UI_Txt_Width" Text="1000" Height="26" VerticalContentAlignment="Center" Padding="5,0"/>
                         </StackPanel>
                         <StackPanel Grid.Column="2">
                             <TextBlock Text="Height" Foreground="{StaticResource SubtitleBrush}"/>
                             <TextBox x:Name="UI_Txt_Height" Text="500" Height="26" VerticalContentAlignment="Center" Padding="5,0"/>
                         </StackPanel>
                     </Grid>
                     
                     <TextBlock Text="Vertical Offset (mm)" Foreground="{StaticResource SubtitleBrush}"/>
                     <TextBox x:Name="UI_Txt_Offset" Text="300" Height="26" VerticalContentAlignment="Center" Padding="5,0"/>

                 </StackPanel>
             </Border>
             
             <!-- RIGHT: SOURCE SELECT & PREVIEW -->
             <Grid Grid.Column="2">
                 <Grid.RowDefinitions>
                     <RowDefinition Height="*"/> <!-- View List -->
                     <RowDefinition Height="5"/>
                     <RowDefinition Height="Auto"/> <!-- Preview Header -->
                     <RowDefinition Height="150"/> <!-- Preview List -->
                 </Grid.RowDefinitions>

                 <!-- TOP: SELECT SOURCE VIEW -->
                 <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Padding="0">
                     <Grid>
                         <Grid.RowDefinitions>
                             <RowDefinition Height="Auto"/>
                             <RowDefinition Height="Auto"/>
                             <RowDefinition Height="*"/>
                         </Grid.RowDefinitions>
                         
                         <!-- Header -->
                         <Border Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}" Padding="15,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                             <TextBlock Text="Select Source View" Style="{StaticResource SectionLabelStyle}" Margin="0"/>
                         </Border>
                         
                         <!-- Filters -->
                         <StackPanel Grid.Row="1" Margin="15,10">
                             <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                 <CheckBox x:Name="UI_Check_Views" Content="Views" IsChecked="True" Margin="0,0,15,0" Checked="OnViewFilterChanged" Unchecked="OnViewFilterChanged"/>
                                 <CheckBox x:Name="UI_Check_Templates" Content="Templates" IsChecked="True" Checked="OnViewFilterChanged" Unchecked="OnViewFilterChanged"/>
                             </StackPanel>
                             <TextBox x:Name="UI_Txt_Search" Style="{StaticResource InputStyle}" Tag="Filter views..." TextChanged="OnViewSearchChanged"/>
                         </StackPanel>
                         
                         <!-- List -->
                         <ListBox x:Name="UI_List_Views" Grid.Row="2" Margin="15,0,15,15" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="UI_List_Views_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="5,2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                         </ListBox>
                     </Grid>
                 </Border>

                 <!-- BOTTOM: FILTER PREVIEW -->
                 <Border Grid.Row="3" Style="{StaticResource SectionBorderStyle}" Padding="0">
                     <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}" Padding="15,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock x:Name="UI_Label_Filters" Text="Existing Filters in Selected View" Style="{StaticResource SectionLabelStyle}" FontSize="11" Margin="0"/>
                        </Border>
                        
                        <ListBox x:Name="UI_List_Filters" Grid.Row="1" Margin="10" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource LabelBrush}" Padding="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                     </Grid>
                 </Border>
             </Grid>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" x:Name="UI_Status_Text" Text="Ready" VerticalAlignment="Center" Style="{StaticResource StatusLabelStyle}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="UI_Btn_Cancel" Content="Cancel" Width="90" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Btn_Cancel_Click"/>
                    <Button x:Name="UI_Btn_Create" Content="Run" Width="140" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Btn_Create_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
