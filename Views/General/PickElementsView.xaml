<Window x:Class="antiGGGravity.Views.General.PickElementsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Elements" Height="550" Width="500" MinHeight="400" MinWidth="480"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip" ShowInTaskbar="False" Topmost="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <DynamicResource ResourceKey="PremiumWindowChrome"/>
    </WindowChrome.WindowChrome>
    
    <Border Style="{DynamicResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource CompanyLogoStyle}"/>
                        <TextBlock Style="{DynamicResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Pick Elements" Style="{DynamicResource PremiumTitleStyle}"/>
                            <TextBlock Text="Category Selection" Style="{DynamicResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{DynamicResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Btn_Cancel_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="25,15,25,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Quick Picks Title -->
                    <RowDefinition Height="Auto"/> <!-- Quick Picks Buttons -->
                    <RowDefinition Height="Auto"/> <!-- Filter Title -->
                    <RowDefinition Height="Auto"/> <!-- Filter Input -->
                    <RowDefinition Height="*"/>    <!-- Category List -->
                </Grid.RowDefinitions>
                
                <!-- Quick Picks Section -->
                <TextBlock Text="Quick Picks" FontSize="11" FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,8" Grid.Row="0"/>
                
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Row 1: Structural/Common -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="Foundation" Tag="Foundation" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="10,4" FontSize="12" Height="28"/>
                        <Button Content="Wall" Tag="Wall" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="10,4" FontSize="12" Height="28"/>
                        <Button Content="Floor" Tag="Floor" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="10,4" FontSize="12" Height="28"/>
                        <Button Content="Beam" Tag="Beam" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="10,4" FontSize="12" Height="28"/>
                        <Button Content="Column" Tag="Column" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="10,4" FontSize="12" Height="28"/>
                        <Button Content="Roof" Tag="Roof" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="10,4" FontSize="12" Height="28"/>
                        <Button Content="Rebar" Tag="Rebar" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,0,5" Padding="10,4" FontSize="12" Height="28"/>
                    </WrapPanel>

                    <!-- Row 2: Model Elements (3D) & Annotation Elements (2D) -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="Pick All 3D Elements (Model)" Tag="All3D" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="15,4" FontSize="12" Height="28"/>
                        <Button Content="Pick All 2D Elements (Annotation)" Tag="All2D" Click="UI_Btn_QuickPick_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,0,5" Padding="15,4" FontSize="12" Height="28"/>
                    </WrapPanel>

                    <!-- Row 3: Custom Categories -->
                    <WrapPanel x:Name="UI_Panel_CustomPicks" Grid.Row="2" Margin="0,0,0,0">
                        <Button Content="⚙️ Add Custom..." Click="UI_Btn_AddCustom_Click" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,5,5" Padding="10,4" FontSize="12" Height="28" Foreground="#0078D7" BorderBrush="#0078D7"/>
                    </WrapPanel>
                </Grid>

                <!-- Full Category List Section -->
                <TextBlock Text="All Categories" FontSize="11" FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,8" Grid.Row="2"/>

                <TextBox x:Name="UI_Text_Filter" Grid.Row="3" Height="32" Margin="0,0,0,10" 
                         Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"
                         TextChanged="UI_Text_Filter_TextChanged"
                         Tag="Search full category list..."/>
                
                <ListBox x:Name="UI_List_Categories" Grid.Row="4" BorderThickness="1" BorderBrush="#E0E0E0" Background="White"
                         SelectionChanged="UI_List_Categories_SelectionChanged" 
                         MouseDoubleClick="UI_List_Categories_MouseDoubleClick" Padding="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" Padding="8,10" Background="Transparent">
                                <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#333333"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>
