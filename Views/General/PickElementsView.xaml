<Window x:Class="antiGGGravity.Views.General.PickElementsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Elements" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Category Selection" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBox x:Name="UI_Text_Filter" Height="30" Margin="0,0,0,10" 
                     TextAlignment="Left" VerticalContentAlignment="Center" Padding="5,0"
                     TextChanged="UI_Text_Filter_TextChanged"
                     Tag="Search categories..."/>
            
            <ListBox x:Name="UI_List_Categories" Grid.Row="1" BorderThickness="0" Background="Transparent"
                     SelectionChanged="UI_List_Categories_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" Padding="5,10">
                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#2C3E50"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="{DynamicResource FooterPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="UI_Status_Text" Text="Select category" Style="{StaticResource StatusLabelStyle}"/>

                <Button Content="Cancel" Click="UI_Btn_Cancel_Click" Width="80" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2" Content="Pick" Click="UI_Btn_Run_Click" Width="100" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
