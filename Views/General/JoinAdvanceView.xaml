<Window x:Class="antiGGGravity.Views.General.JoinAdvanceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Join Advance" Height="600" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="10"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{DynamicResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource CompanyLogoStyle}"/>
                        <TextBlock Style="{DynamicResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Join Advance" Style="{DynamicResource PremiumTitleStyle}"/>
                            <TextBlock Text="Advanced geometry joining with priority mode" Style="{DynamicResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{DynamicResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Btn_Cancel_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- OPTIONS -->
            <Border Grid.Row="1" Margin="25,15,25,0" Background="#FAFAFA" CornerRadius="8" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" Padding="15,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Operation:" Style="{DynamicResource PremiumSectionLabelStyle}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <RadioButton x:Name="UI_Radio_Join" Content="Join" IsChecked="True" VerticalAlignment="Center" Margin="0,0,25,0" Foreground="#333333" FontSize="14" FontWeight="SemiBold"/>
                    <RadioButton x:Name="UI_Radio_Unjoin" Content="Unjoin" VerticalAlignment="Center" Foreground="#333333" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- DUAL PANEL -->
            <Grid Grid.Row="2" Margin="25,12,25,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ==================== LEFT: PRIORITY ==================== -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Structural Defaults (Red) -->
                            <RowDefinition Height="Auto"/> <!-- NEW: Select All for Prelist -->
                            <RowDefinition Height="Auto"/> <!-- Project Categories Header -->
                            <RowDefinition Height="Auto"/> <!-- Search Box -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Panel Header -->
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="✂️ Priority (Cutting Elements)" Style="{DynamicResource PremiumSectionLabelStyle}" Margin="0"/>
                        </Border>

                        <!-- Neutral: Pre-defined Categories -->
                        <Border Grid.Row="1" Margin="8,8,8,0" Background="#F9FAFB" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1" Padding="4">
                            <StackPanel>
                                <TextBlock Text="Structural Default (Double-click to remove)" FontSize="10" FontWeight="Bold" Foreground="#4B5563" Margin="6,2,0,4" Opacity="0.7"/>
                                <ItemsControl x:Name="UI_Defaults_Left">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Background="Transparent" MouseDown="UI_DefaultLeft_MouseDown">
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Padding="4,3" Margin="2,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="#111827" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Select All Checkbox for Prelist -->
                        <Border Grid.Row="2" Padding="12,12" Background="Transparent" Margin="0,5">
                            <CheckBox x:Name="UI_Check_LeftAll" Content="Select All (Pre-defined)" FontSize="11" Foreground="#4B5563" 
                                      Checked="UI_Check_LeftAll_Changed" Unchecked="UI_Check_LeftAll_Changed"/>
                        </Border>

                        <Border Grid.Row="3" Margin="8,4,8,0" Padding="0">
                            <TextBlock Text="Project Categories" FontSize="11" FontWeight="Bold" Foreground="#4B5563" Margin="6,0,0,0"/>
                        </Border>

                        <!-- Search Box -->
                        <Border Grid.Row="4" Margin="8,4,8,0" Background="#F9FAFB" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1" Padding="2">
                            <TextBox x:Name="UI_Search_Left" Height="28" BorderThickness="0" Background="Transparent"
                                     FontSize="12.5" VerticalContentAlignment="Center" Padding="8,0" Foreground="#111827"
                                     TextChanged="UI_Search_Left_Changed"/>
                        </Border>

                        <!-- Project Category List -->
                        <Border Grid.Row="5" Margin="8,4,8,8" Background="#FFFFFF" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ListBox x:Name="UI_List_Left" BorderThickness="0" Background="Transparent" Margin="2,2" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Padding="6,4" MouseDown="UI_ProjectLeft_MouseDown">
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="#111827"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Border>

                <!-- ARROW -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="▶" HorizontalAlignment="Center" FontSize="24" Foreground="#3F51B5" Opacity="0.5"/>
                </StackPanel>

                <!-- ==================== RIGHT: SECONDARY ==================== -->
                <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Structural Defaults (Red) -->
                            <RowDefinition Height="Auto"/> <!-- NEW: Select All for Prelist -->
                            <RowDefinition Height="Auto"/> <!-- Project Categories Header -->
                            <RowDefinition Height="Auto"/> <!-- Search Box -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Panel Header -->
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="🧱 Secondary (To Be Joined)" Style="{DynamicResource PremiumSectionLabelStyle}" Margin="0"/>
                        </Border>

                        <!-- Neutral: Pre-defined Categories -->
                        <Border Grid.Row="1" Margin="8,8,8,0" Background="#F9FAFB" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1" Padding="4">
                            <StackPanel>
                                <TextBlock Text="Structural Default (Double-click to remove)" FontSize="10" FontWeight="Bold" Foreground="#4B5563" Margin="6,2,0,4" Opacity="0.7"/>
                                <ItemsControl x:Name="UI_Defaults_Right">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Background="Transparent" MouseDown="UI_DefaultRight_MouseDown">
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Padding="4,3" Margin="2,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="#111827" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Select All Checkbox for Prelist -->
                        <Border Grid.Row="2" Padding="12,12" Background="Transparent" Margin="0,5">
                            <CheckBox x:Name="UI_Check_RightAll" Content="Select All (Pre-defined)" FontSize="11" Foreground="#4B5563"
                                      Checked="UI_Check_RightAll_Changed" Unchecked="UI_Check_RightAll_Changed"/>
                        </Border>

                        <Border Grid.Row="3" Margin="8,4,8,0" Padding="0">
                            <TextBlock Text="Project Categories" FontSize="11" FontWeight="Bold" Foreground="#4B5563" Margin="6,0,0,0"/>
                        </Border>

                        <!-- Search Box -->
                        <Border Grid.Row="4" Margin="8,4,8,0" Background="#F9FAFB" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1" Padding="2">
                            <TextBox x:Name="UI_Search_Right" Height="28" BorderThickness="0" Background="Transparent"
                                     FontSize="12.5" VerticalContentAlignment="Center" Padding="8,0" Foreground="#111827"
                                     TextChanged="UI_Search_Right_Changed"/>
                        </Border>

                        <!-- Project Category List -->
                        <Border Grid.Row="5" Margin="8,4,8,8" Background="#FFFFFF" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ListBox x:Name="UI_List_Right" BorderThickness="0" Background="Transparent" Margin="2,2" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Padding="6,4" MouseDown="UI_ProjectRight_MouseDown">
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="#111827"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- FOOTER (no legend) -->
            <Border Grid.Row="3" Background="#FAFAFA" Padding="20,12" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="UI_Status_Text" Text="Select categories and process." Foreground="#999999" VerticalAlignment="Center"/>
                        <Button x:Name="UI_Btn_Copy" Content="📋 Copy Log" Margin="8,0,0,0" ToolTip="Copy detailed execution log"
                                Padding="6,2" FontSize="11" Foreground="#4A708B" Background="#EEEEEE" BorderBrush="#CCCCCC" BorderThickness="1"
                                Click="UI_Btn_Copy_Click" Cursor="Hand"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="UI_Btn_Cancel" Content="Close" Width="90" Style="{DynamicResource PremiumPrimaryButtonStyle}" Margin="0,0,12,0" Click="UI_Btn_Cancel_Click"/>
                        <Button x:Name="UI_Btn_Run" Content="Process" Width="140" Style="{DynamicResource PremiumActionButtonStyle}" Click="UI_Btn_Run_Click"/>
                    </StackPanel>

                    <!-- Resize Grip -->
                    <ResizeGrip Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="-10,0,-15,-8" Opacity="0.5" Width="20" Height="20" Cursor="SizeNWSE"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
