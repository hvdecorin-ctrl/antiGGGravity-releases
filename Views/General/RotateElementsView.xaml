<Window x:Class="antiGGGravity.Views.General.RotateElementsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rotate Elements" Height="300" Width="320"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="ROTATE ELEMENTS" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <StackPanel Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Rotation Angle (Degrees)" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox x:Name="UI_Text_Angle" Text="90" Height="36" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                    <TextBlock x:Name="UI_Status" Text="Angle is in degrees (counter-clockwise)" Foreground="{DynamicResource SubtitleBrush}" FontSize="11" Margin="2,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="UI_Btn_Cancel" Grid.Column="1" Content="Cancel" Width="90" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Click="UI_Btn_Cancel_Click"/>
                <Button x:Name="UI_Btn_Run" Grid.Column="2" Content="Rotate" Width="100" Style="{StaticResource PrimaryButtonStyle}" Click="UI_Btn_Run_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
