<Window x:Class="antiGGGravity.Views.General.PrintView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Drawing Set" Height="1000" Width="650"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="7"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Print Drawing Set" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Export sheets to PDF or DWG with automatic sorting" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Btn_Cancel_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/> <!-- Selection -->
                    <ColumnDefinition Width="20"/>   <!-- Spacer -->
                    <ColumnDefinition Width="1.2*"/> <!-- Settings -->
                </Grid.ColumnDefinitions>

                <!-- SELECTION PANEL -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10" CornerRadius="8,8,0,0" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Select Drawings" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0"/>
                        </Border>

                        <!-- UNIFIED SELECTION SOURCE -->
                        <StackPanel Grid.Row="1" Margin="15,15,15,10">
                            <TextBlock Text="Drawing Selection Source" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>
                            <ComboBox x:Name="UI_Combo_Source" Height="32" DisplayMemberPath="Name" SelectionChanged="UI_Combo_Source_SelectionChanged"/>
                        </StackPanel>

                        <!-- SEARCH -->
                        <Grid Grid.Row="2" Margin="15,5,15,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="UI_Check_All" VerticalAlignment="Center" Margin="0,0,10,0" IsChecked="True" Checked="UI_Check_All_Checked" Unchecked="UI_Check_All_Unchecked" IsEnabled="{Binding CanToggleSelection}"/>
                            <TextBox x:Name="UI_Txt_Search" Grid.Column="1" Height="32" Padding="25,0,5,0" 
                                     VerticalContentAlignment="Center" BorderBrush="#E0E0E0" TextChanged="UI_Txt_Search_TextChanged"/>
                        </Grid>

                        <ListBox x:Name="UI_List_Sheets" Grid.Row="3" Margin="15,5,15,15" SelectionMode="Extended" BorderThickness="1" BorderBrush="#E0E0E0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0" IsEnabled="{Binding DataContext.CanToggleSelection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding NumberName}" FontWeight="SemiBold" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- RIGHT: SETTINGS -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- PRINTER -->
                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Select Printer" Style="{StaticResource PremiumSectionLabelStyle}"/>
                                <ComboBox x:Name="UI_Combo_Printers" Height="32" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- PAGE SETTINGS -->
                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Page Setting (Print Setup)" Style="{StaticResource PremiumSectionLabelStyle}"/>
                                <ComboBox x:Name="UI_Combo_Setups" Height="32" DisplayMemberPath="Name" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- CAD SETTINGS -->
                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15" Visibility="{Binding ElementName=UI_Radio_DWG, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="CAD Export Setup" Style="{StaticResource PremiumSectionLabelStyle}"/>
                                <ComboBox x:Name="UI_Combo_CadSetups" Height="32" DisplayMemberPath="Name" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- EXPORT FORMAT -->
                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Export Format" Style="{StaticResource PremiumSectionLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="UI_Radio_PDF" Grid.Column="0" Content="PDF" IsChecked="True" Margin="0,5"/>
                                    <RadioButton x:Name="UI_Radio_DWG" Grid.Column="1" Content="DWG" Margin="0,5"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- NAMING -->
                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="File Naming" Style="{StaticResource PremiumSectionLabelStyle}"/>
                                <TextBlock Text="Format Example: {number}.pdf" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="UI_Txt_Naming" Text="{}{number}" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0"/>
                                <TextBlock Text="Placeholders: {number}, {name}, {index}, {date}" Foreground="#999999" Margin="2,8,0,0" FontSize="10" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- DESTINATION -->
                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Output Path" Style="{StaticResource PremiumSectionLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="UI_Txt_Path" Height="32" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#E0E0E0" IsReadOnly="True"/>
                                    <Button Grid.Column="1" Content="..." Width="32" Height="32" Margin="5,0,0,0" Style="{StaticResource PremiumPrimaryButtonStyle}" Click="UI_Btn_Browse_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- PDF OPTIONS -->
                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15" Visibility="{Binding ElementName=UI_Radio_PDF, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="PDF Options" Style="{StaticResource PremiumSectionLabelStyle}"/>
                                <CheckBox x:Name="UI_Check_Combine" Content="Combine into one file" IsChecked="True" Margin="0,5,0,0"/>
                                <CheckBox x:Name="UI_Check_HideCrop" Content="Hide Crop Boundaries" IsChecked="True" Margin="0,5,0,0"/>
                                <CheckBox x:Name="UI_Check_HideRef" Content="Hide Reference Planes" IsChecked="True" Margin="0,5,0,0"/>
                                <CheckBox x:Name="UI_Check_Color" Content="Color Export (Force Color)" IsChecked="True" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="15,10" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="UI_Txt_Status" Text="Ready" Foreground="#999999" FontSize="11"/>
                        <ProgressBar x:Name="UI_Progress" Height="10" Margin="0,5,20,0" Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                         <Button x:Name="UI_Btn_Cancel" Content="Cancel" Width="100" Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,0,10,0" Click="UI_Btn_Cancel_Click"/>
                         <Button x:Name="UI_Btn_Print" Content="Print Set" Width="150" Style="{StaticResource PremiumActionButtonStyle}" Click="UI_Btn_Print_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SUCCESS OVERLAY -->
            <Grid x:Name="UI_Overlay_Success" Grid.RowSpan="3" Visibility="Collapsed">
                <Border Background="#CC000000" CornerRadius="12"/>
                <Border Background="White" Width="300" Height="250" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="60" Foreground="#28A745" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="Export Complete!" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Files have been saved successfully." Foreground="#666666" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Row="1" Content="Great!" Width="120" Height="36" Margin="0,0,0,25" 
                                Style="{StaticResource PremiumPrimaryButtonStyle}" Click="UI_Btn_Cancel_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
