<Window x:Class="antiGGGravity.Views.General.ModifyWallConstraintsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modify Wall Constraints" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Wall Constraints" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            <TextBlock Text="Modify Base Constraint" Style="{StaticResource SectionLabelStyle}"/>
            <CheckBox x:Name="UI_Check_Base" Content="Modify base level" IsChecked="True" Margin="0,0,0,5"/>
            <ComboBox x:Name="UI_Combo_Base" Height="30" Margin="0,0,0,20">
                 <!-- Levels populated here -->
            </ComboBox>

            <TextBlock Text="Modify Top Constraint" Foreground="#34495E" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <CheckBox x:Name="UI_Check_Top" Content="Modify Top Level" IsChecked="True" Margin="0,0,0,5"/>
            <ComboBox x:Name="UI_Combo_Top" Height="30" Margin="0,0,0,10">
                 <!-- Levels populated here -->
            </ComboBox>
            
            <TextBlock x:Name="UI_Selection_Info" Text="Confirm levels and click Modify." Style="{StaticResource StatusLabelStyle}" Margin="2,10,0,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="{DynamicResource FooterPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="UI_Status_Text" Text="Ready" Style="{StaticResource StatusLabelStyle}"/>

                <Button Content="Cancel" Click="UI_Btn_Cancel_Click" Width="80" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2" Content="Modify" Click="UI_Btn_Run_Click" Width="100" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
