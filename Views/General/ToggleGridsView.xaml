<Window x:Class="antiGGGravity.Views.General.ToggleGridsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toggle Grid Bubbles" Height="380" Width="350"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Grid Bubbles" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            <TextBlock Text="Select bubble directions to show:" Style="{StaticResource SectionLabelStyle}"/>
            
            <CheckBox x:Name="UI_Check_All" Content="Select All" Margin="0,0,0,10" FontWeight="Bold" Click="UI_Check_All_Click"/>
            <Separator Margin="0,5,0,15" Background="{DynamicResource SeparatorBrush}"/>
            
            <UniformGrid Columns="2">
                <CheckBox x:Name="UI_Check_Top" Content="Top" Margin="5" IsChecked="True"/>
                <CheckBox x:Name="UI_Check_Bottom" Content="Bottom" Margin="5" IsChecked="True"/>
                <CheckBox x:Name="UI_Check_Left" Content="Left" Margin="5" IsChecked="True"/>
                <CheckBox x:Name="UI_Check_Right" Content="Right" Margin="5" IsChecked="True"/>
            </UniformGrid>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="{DynamicResource FooterPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="UI_Status_Text" Text="Ready" Style="{StaticResource StatusLabelStyle}"/>

                <Button Content="Cancel" Click="UI_Btn_Cancel_Click" Width="80" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2" Content="Toggle" Click="UI_Btn_Run_Click" Width="100" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
