<Window x:Class="antiGGGravity.Views.General.ToggleGridsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toggle Grid Bubbles" Height="480" Width="450"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Grid Bubbles" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="{DynamicResource ContentMargin}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Select which grid bubble directions to show:" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <!-- Directional Selector Grid -->
                <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <!-- TOP -->
                    <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Top" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <CheckBox x:Name="UI_Check_Top" HorizontalAlignment="Center" IsChecked="True"/>
                    </StackPanel>

                    <!-- LEFT -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Left" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <CheckBox x:Name="UI_Check_Left" VerticalAlignment="Center" IsChecked="True"/>
                    </StackPanel>

                    <!-- CENTER INDICATOR -->
                    <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource BrandPrimaryBrush}" CornerRadius="4" Margin="15" Opacity="0.3">
                        <TextBlock Text="GRID" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- RIGHT -->
                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <CheckBox x:Name="UI_Check_Right" VerticalAlignment="Center" IsChecked="True"/>
                        <TextBlock Text="Right" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- BOTTOM -->
                    <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <CheckBox x:Name="UI_Check_Bottom" HorizontalAlignment="Center" IsChecked="True"/>
                        <TextBlock Text="Bottom" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Select All -->
                <CheckBox Grid.Row="2" x:Name="UI_Check_All" Content="Select All" FontWeight="SemiBold" Margin="0,15,0,0" Click="UI_Check_All_Click" IsChecked="True"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="{DynamicResource FooterPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="UI_Status_Text" Text="Ready" Style="{StaticResource StatusLabelStyle}"/>

                <Button Content="Cancel" Click="UI_Btn_Cancel_Click" Width="80" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2" Content="Apply" Click="UI_Btn_Run_Click" Width="100" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
