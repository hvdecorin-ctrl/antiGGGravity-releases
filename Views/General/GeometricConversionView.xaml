<Window x:Class="antiGGGravity.Views.General.GeometricConversionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geometric Conversion" Height="450" Width="380"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="UI_Title" Text="Convert Regions" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            <TextBlock x:Name="UI_Label_Type" Text="Select Type:" Style="{StaticResource SectionLabelStyle}"/>
            <ComboBox x:Name="UI_Combo_Type" Height="30" Margin="0,0,0,20"/>

            <TextBlock Text="Select Level:" Style="{StaticResource SectionLabelStyle}"/>
            <ComboBox x:Name="UI_Combo_Level" Height="30" Margin="0,0,0,20"/>

            <TextBlock Text="Height Offset (mm):" Style="{StaticResource SectionLabelStyle}"/>
            <TextBox x:Name="UI_Text_Offset" Text="0" Style="{StaticResource FilterTextBoxStyle}"/>
            
            <TextBlock x:Name="UI_Selection_Info" Text="Generate geometry from region outlines." Style="{StaticResource StatusLabelStyle}" Margin="2,15,0,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="{DynamicResource FooterPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="UI_Status_Text" Text="Ready" Style="{StaticResource StatusLabelStyle}"/>

                <Button Content="Cancel" Click="UI_Btn_Cancel_Click" Width="80" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button x:Name="UI_Btn_Run" Content="Create" Click="UI_Btn_Run_Click" Width="100" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
