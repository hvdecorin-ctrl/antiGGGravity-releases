<Window x:Class="antiGGGravity.Views.Views.SetCropView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Crop" Height="150" Width="300"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select options to set crop region:" 
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Foreground="#333333"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Draw" Click="Draw_Click" Width="80"/>
            <Button Content="Reset" Click="Reset_Click" Width="80"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
