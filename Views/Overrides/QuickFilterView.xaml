<Window x:Class="antiGGGravity.Views.Overrides.QuickFilterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Filter &amp; Color" Height="800" Width="660"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Height" Value="36"/>
                <Setter Property="Background" Value="#F8F9FA"/>
                <Setter Property="BorderBrush" Value="{StaticResource PremiumBorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="15,0"/>
                <Setter Property="Foreground" Value="#333333"/>
            </Style>
            
            <Style TargetType="DataGridCell">
                 <Setter Property="Padding" Value="15,0"/>
                 <Setter Property="VerticalContentAlignment" Value="Center"/>
                 <Setter Property="BorderThickness" Value="0"/>
                 <!-- Ensure content fits nicely without inner borders -->
                 <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Filter &amp; Color" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Visualize parameter values with color overrides" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Btn_Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="UI_Column_Left" Width="280" MinWidth="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" 
                              Background="Transparent" Width="10" Margin="0" ShowsPreview="True"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- Left Panel: Selection -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/> <!-- Search Box -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Category:" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="UI_Combo_Category" Grid.Row="1" Height="32" Margin="0,0,0,20"
                                  VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E0E0E0"
                                  SelectionChanged="UI_Combo_Category_SelectionChanged"/>

                        <TextBlock Grid.Row="2" Text="Parameter:" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,8"/>
                        
                        <!-- Search Box -->
                        <TextBox x:Name="UI_Txt_Search" Grid.Row="3" Height="32" Padding="30,0,8,0" VerticalContentAlignment="Center" 
                                 Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,15" 
                                 TextChanged="UI_Txt_Search_TextChanged"
                                 Tag="Search parameters..."/>

                        <ListBox x:Name="UI_List_Parameters" Grid.Row="4" Background="White" BorderBrush="#E0E0E0"
                                 SelectionMode="Single" SelectionChanged="UI_List_Parameters_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Padding="8,5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Right Panel: Values -->
                <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10" CornerRadius="8,8,0,0" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <!-- Removed Values & Colors text as requested -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="UI_Btn_Randomize" Content="Random Colors" Width="120" Height="28" Padding="10,0" FontSize="12"
                                            Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,0,10,0" Click="UI_Btn_Randomize_Click"/>
                                    <Button x:Name="UI_Btn_Gradient" Content="Gradient" Width="100" Height="28" Padding="10,0" FontSize="12"
                                            Style="{StaticResource PremiumPrimaryButtonStyle}" Click="UI_Btn_Gradient_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1" x:Name="UI_Grid_Values" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" Background="White" BorderBrush="Transparent" BorderThickness="0"
                                  RowHeight="36" AlternatingRowBackground="#FAFAFA" GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F0F0F0" Margin="1">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="*" IsReadOnly="True">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.Header>
                                        <Grid HorizontalAlignment="Stretch">
                                            <TextBox x:Name="UI_Txt_ValueSearch" 
                                                     Height="28" Margin="0,2"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource PremiumTextBoxStyle}"
                                                     Tag="Search list..."
                                                     TextChanged="UI_Txt_ValueSearch_TextChanged"/>
                                        </Grid>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Padding="15,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80" IsReadOnly="True" />
                                
                                <!-- Color Column -->
                                <DataGridTemplateColumn Header="Color" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding ColorBrush}" Width="70" Height="24" HorizontalAlignment="Left"
                                                    CornerRadius="4" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="1"
                                                    Cursor="Hand" MouseLeftButtonDown="ColorBorder_MouseDown"
                                                    ToolTip="Click to change color"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="15,10" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Create Legend" Width="110" Height="30"
                            Style="{StaticResource PremiumPrimaryButtonStyle}"
                            Click="UI_Btn_Legend_Click"/>

                    <Button Grid.Column="1" Content="Create Filters" Width="110" Height="30" Margin="10,0,0,0"
                            Style="{StaticResource PremiumPrimaryButtonStyle}"
                            Click="UI_Btn_Filters_Click"/>

                    <Button Grid.Column="2" Content="Isolate" Width="90" Height="30" Margin="10,0,0,0"
                            Style="{StaticResource PremiumPrimaryButtonStyle}"
                            Click="UI_Btn_Isolate_Click"/>

                    <Button Grid.Column="4" Content="Reset View" Width="100" Height="30" Margin="0,0,10,0"
                            Style="{StaticResource PremiumPrimaryButtonStyle}"
                            Click="UI_Btn_Reset_Click"/>

                    <Button Grid.Column="5" Content="Apply Colors" Width="120" Height="30"
                            Style="{StaticResource PremiumActionButtonStyle}"
                            Click="UI_Btn_Apply_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
