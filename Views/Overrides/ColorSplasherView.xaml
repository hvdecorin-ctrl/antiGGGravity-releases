<Window x:Class="antiGGGravity.Views.Overrides.ColorSplasherView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Color Splasher" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="10,0"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource HeaderPadding}">
                <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                <Rectangle Width="2" Height="24" Fill="{DynamicResource SeparatorBrush}" Margin="15,0" VerticalAlignment="Center"/>
                <TextBlock Text="Color Splasher" Style="{StaticResource BrandSubtitleStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Selection -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/> <!-- Search Box -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Category" Style="{StaticResource SectionLabelStyle}"/>
                <ComboBox x:Name="UI_Combo_Category" Grid.Row="1" Height="30" Margin="0,0,0,20"
                          Padding="5" SelectionChanged="UI_Combo_Category_SelectionChanged"/>

                <TextBlock Grid.Row="2" Text="Parameter" Style="{StaticResource SectionLabelStyle}"/>
                
                <!-- Search Box -->
                <TextBox x:Name="UI_Txt_Search" Grid.Row="3" Style="{StaticResource FilterTextBoxStyle}" 
                         Margin="0,0,0,10" TextChanged="UI_Txt_Search_TextChanged"
                         Tag="Search parameters..."/>

                <ListBox x:Name="UI_List_Parameters" Grid.Row="4" Background="White" BorderBrush="{DynamicResource BorderBrush}"
                         SelectionMode="Single" SelectionChanged="UI_List_Parameters_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Right Panel: Values -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Values &amp; Colors" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" Margin="0"/>
                    <Button x:Name="UI_Btn_Randomize" Content="Random Colors" Margin="20,0,0,0" Width="120"
                            Style="{StaticResource PrimaryButtonStyle}" Click="UI_Btn_Randomize_Click"/>
                    <Button x:Name="UI_Btn_Gradient" Content="Gradient" Margin="10,0,0,0" Width="100"
                            Style="{StaticResource PrimaryButtonStyle}" Click="UI_Btn_Gradient_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="UI_Grid_Values" AutoGenerateColumns="False" 
                          CanUserAddRows="False" Background="White" BorderBrush="{DynamicResource BorderBrush}"
                          RowHeight="32" AlternatingRowBackground="#FAFAFA" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80" IsReadOnly="True"/>
                        
                        <!-- Color Column -->
                        <DataGridTemplateColumn Header="Color" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ColorBrush}" Width="60" Height="20" 
                                            CornerRadius="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="{DynamicResource FooterPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Create Legend" Width="120"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="UI_Btn_Legend_Click"/>

                <Button Grid.Column="1" Content="Create Filters" Width="120" Margin="10,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="UI_Btn_Filters_Click"/>

                <Button Grid.Column="3" Content="Reset" Width="100" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="UI_Btn_Reset_Click"/>

                <Button Grid.Column="4" Content="Apply" Width="100" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="UI_Btn_Apply_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
