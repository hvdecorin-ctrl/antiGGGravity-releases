<Window x:Class="antiGGGravity.Views.Samples.SinglePanelSample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Single Panel Sample" Height="800" Width="800"
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="SINGLE PANEL SAMPLE" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{DynamicResource ContentMargin}">
            <StackPanel>
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Settings Section" Style="{StaticResource SectionLabelStyle}"/>
                        
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Parameter Name:" VerticalAlignment="Center" FontSize="{DynamicResource StandardFontSize}"/>
                            <TextBox Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Option Choice:" VerticalAlignment="Center" FontSize="{DynamicResource StandardFontSize}"/>
                            <ComboBox Grid.Column="1" Height="28" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Option A" IsSelected="True"/>
                                <ComboBoxItem Content="Option B"/>
                            </ComboBox>
                        </Grid>
                        
                        <CheckBox Content="Enable Advanced Features" Margin="0,15,0,0" FontSize="{DynamicResource StandardFontSize}"/>
                    </StackPanel>
                </Border>
                
                <Border Style="{StaticResource SectionBorderStyle}" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="Additional Configuration" Style="{StaticResource SectionLabelStyle}"/>
                        <TextBlock Text="This section demonstrates how to stack multiple section borders within a single panel layout." 
                                   TextWrapping="Wrap" FontSize="{DynamicResource StandardFontSize}" Foreground="{DynamicResource SubtitleBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready to innovate • Single Panel Sample" Style="{StaticResource StatusLabelStyle}"/>
                
                <Button x:Name="UI_Btn_Cancel" Grid.Column="1" Content="Reset" Width="100" 
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" 
                        Click="UI_Btn_Cancel_Click"/>
                
                <Button x:Name="UI_Btn_Apply" Grid.Column="2" Content="Apply" Width="160" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="UI_Btn_Apply_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
