<Window x:Class="antiGGGravity.Views.Samples.TriplePanelSample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triple Panel Sample" Height="800" Width="1000"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource HeaderHeight}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{DynamicResource FooterHeight}"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="{DynamicResource HeaderPadding}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BrandTitleStyle}"/>
                    <Rectangle Width="2" Height="20" Fill="{DynamicResource SeparatorBrush}" Margin="15,0"/>
                    <TextBlock Text="TRIPLE PANEL SAMPLE" Style="{StaticResource BrandSubtitleStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="{DynamicResource ContentMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/> <!-- Gap -->
                <ColumnDefinition Width="1.2*"/> <!-- Center usually slightly wider -->
                <ColumnDefinition Width="15"/> <!-- Gap -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Hierarchy/Nav -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Structure" Style="{StaticResource SectionLabelStyle}"/>
                    <TreeView Grid.Row="1" BorderThickness="0">
                        <TreeViewItem Header="Level 1" IsExpanded="True">
                            <TreeViewItem Header="Category A"/>
                            <TreeViewItem Header="Category B"/>
                        </TreeViewItem>
                        <TreeViewItem Header="Level 2">
                            <TreeViewItem Header="Category C"/>
                        </TreeViewItem>
                    </TreeView>
                </Grid>
            </Border>

            <!-- CENTER PANEL: Work Area -->
            <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Configuration Area" Style="{StaticResource SectionLabelStyle}"/>
                    
                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <TextBlock Text="Main Parameter:" Style="{StaticResource StatusLabelStyle}" Margin="0,0,0,5"/>
                        <TextBox Height="28" Margin="0,0,0,15"/>
                        
                        <Separator Margin="0,5,0,15"/>
                        
                        <TextBlock Text="Detailed Sub-settings:" Style="{StaticResource StatusLabelStyle}" Margin="0,0,0,5"/>
                        <ListBox Height="200">
                            <CheckBox Content="Force Overwrite" Margin="5"/>
                            <CheckBox Content="Audit Linked Elements" Margin="5"/>
                            <CheckBox Content="Generate Reports" Margin="5"/>
                        </ListBox>
                    </StackPanel>
                    
                    <Button Grid.Row="2" Content="Reset Default" HorizontalAlignment="Left" Padding="10,5" FontSize="11"/>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Summary/Preview -->
            <Border Grid.Column="4" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Live Summary" Style="{StaticResource SectionLabelStyle}"/>
                    
                    <Border Grid.Row="1" Background="#F9F9FB" BorderBrush="#EEE" BorderThickness="1" Padding="10">
                        <TextBlock Text="Summary details will appear here as you configure the center panel..." 
                                   TextWrapping="Wrap" FontSize="11" Foreground="#888"/>
                    </Border>
                    
                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <TextBlock Text="Validation: ✅ OK" FontSize="12" Foreground="Green" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Padding="{DynamicResource FooterPadding}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready to build • Triple Panel Layout" Style="{StaticResource StatusLabelStyle}"/>
                
                <Button x:Name="UI_Btn_Cancel" Grid.Column="1" Content="Reset" Width="100" 
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" 
                        Click="UI_Btn_Cancel_Click"/>
                
                <Button x:Name="UI_Btn_Apply" Grid.Column="2" Content="Process All" Width="160" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="UI_Btn_Apply_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
