<Window x:Class="antiGGGravity.Views.Management.AddViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Views" Height="600" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ViewItemListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource PremiumListBoxStyle}">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource PremiumBorderBrush}"/>
                <Setter Property="Background" Value="White"/>
            </Style>

            <Style x:Key="SearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource PremiumTextBoxStyle}">
                <Setter Property="Height" Value="35"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Add Views" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Batch place unsheeted views" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="CancelButton_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Search Views" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,8"/>
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchTextBoxStyle}" 
                             TextChanged="SearchBox_TextChanged" Tag="Type to filter..."/>
                </StackPanel>

                <Border Grid.Row="1" BorderThickness="1" BorderBrush="{StaticResource PremiumBorderBrush}" CornerRadius="6">
                    <ListBox x:Name="ViewsListBox" Style="{StaticResource ViewItemListBoxStyle}" 
                             SelectionMode="Extended" MouseDoubleClick="ViewsListBox_MouseDoubleClick" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource PremiumListBoxItemStyle}">
                                <Setter Property="Padding" Value="12,2"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ViewTypeString}" FontWeight="SemiBold" Foreground="{StaticResource BrandPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="25,20" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="UI_Status" VerticalAlignment="Center" Foreground="#999999" Text="Select one or more views"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="AddButton" Content="Add Selected" Width="130" Style="{StaticResource PremiumPrimaryButtonStyle}" Click="AddButton_Click" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
