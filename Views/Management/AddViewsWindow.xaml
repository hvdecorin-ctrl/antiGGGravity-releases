<Window x:Class="antiGGGravity.Views.Management.AddViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Views" Height="600" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        MinHeight="450" MinWidth="350" Topmost="True"
        Loaded="Window_Loaded"
        FocusManager.FocusedElement="{Binding ElementName=SearchBox}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="55" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="10"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="ViewItemTemplate">
                <Grid Margin="0,4" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Background="Transparent" BorderThickness="0" Padding="6,2" HorizontalAlignment="Left" MinWidth="85">
                        <TextBlock Text="{Binding ViewTypeString}" 
                                 FontSize="10"
                                 FontWeight="ExtraBold" 
                                 Foreground="#666666" 
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Grid.Column="1" Text="{Binding Name}" 
                             FontSize="13"
                             Margin="12,0,0,0" 
                             VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>

            <Style x:Key="ViewItemContainerStyle" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,2"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#E6F2FA"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F5F5F5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" Background="White" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource CompanyLogoStyle}"/>
                        <TextBlock Style="{DynamicResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Add Views" Style="{DynamicResource PremiumTitleStyle}"/>
                            <TextBlock Text="Batch Place Unsheeted Views" Style="{DynamicResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{DynamicResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="CancelButton_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Search Views" Style="{DynamicResource PremiumSectionLabelStyle}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                    <Border BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="1" CornerRadius="4" Background="White">
                        <Grid>
                            <TextBlock Text="Type To Filter Views..." Foreground="#A0A0A0" Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="SearchBox" Padding="8" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" BorderThickness="0" CornerRadius="6">
                    <ListBox x:Name="ViewsListBox" 
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Extended" 
                             MouseDoubleClick="ViewsListBox_MouseDoubleClick"
                             SelectionChanged="ListBox_SelectionChanged"
                             ItemTemplate="{StaticResource ViewItemTemplate}"
                             ItemContainerStyle="{StaticResource ViewItemContainerStyle}"/>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="25,20" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="UI_Status" VerticalAlignment="Center" Foreground="#999999" Text="Select One Or More Views"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="AddButton" Content="Add Selected" Width="130" Style="{DynamicResource PremiumPrimaryButtonStyle}" Click="AddButton_Click" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

