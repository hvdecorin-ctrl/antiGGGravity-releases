<Window x:Class="antiGGGravity.Views.Management.AddViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Views to Sheet" Height="400" Width="300"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select Views to Add:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="SearchBox" Height="25" Margin="0,0,0,5" TextChanged="SearchBox_TextChanged" VerticalContentAlignment="Center" />
        <ListBox x:Name="ViewsListBox" Grid.Row="1" SelectionMode="Extended" Margin="0,0,0,10" MouseDoubleClick="ViewsListBox_MouseDoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="AddButton" Content="Add" Width="75" Height="25" Margin="0,0,10,0" Click="AddButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="75" Height="25" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
