<Window x:Class="antiGGGravity.Views.ProjectAudit.FamilyLoadingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Family Loading" Height="800" Width="1200"
        MinHeight="600" MinWidth="650"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="70" CornerRadius="12" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/antiGGGravity;component/Resources/Pre_BrandStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource PremiumBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradientBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource CompanyLogoStyle}"/>
                        <TextBlock Style="{StaticResource CompanyDividerStyle}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Family Loading" Style="{StaticResource PremiumTitleStyle}"/>
                            <TextBlock Text="Bulk load families and types from library" Style="{StaticResource PremiumSubtitleStyle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="✕" 
                            Style="{StaticResource PremiumIconButtonStyle}" Width="30" Height="30"
                            Click="UI_Btn_Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Folder label -->
                    <RowDefinition Height="Auto"/>   <!-- Folder combo -->
                    <RowDefinition Height="Auto"/>   <!-- Family label -->
                    <RowDefinition Height="Auto"/>   <!-- Family filter -->
                    <RowDefinition Height="*"/>      <!-- Family list -->
                    <RowDefinition Height="Auto"/>   <!-- Types label -->
                    <RowDefinition Height="Auto"/>   <!-- Types filter -->
                    <RowDefinition Height="*"/>      <!-- Types list -->
                </Grid.RowDefinitions>

                <!-- Folder Section -->
                <TextBlock Grid.Row="0" Text="Family Folder:" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,8"/>
                <ComboBox x:Name="UI_Combo_Folder" Grid.Row="1" Height="32" Padding="8,0"
                          VerticalContentAlignment="Center" Margin="0,0,0,12"
                          SelectionChanged="UI_Combo_Folder_SelectionChanged"/>

                <!-- Family Section -->
                <TextBlock Grid.Row="2" Text="Select Family:" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,8"/>
                <TextBox x:Name="UI_Text_FamilyFilter" Grid.Row="3" Height="30" Padding="8,0"
                         VerticalContentAlignment="Center" Background="#F9F9F9"
                         BorderBrush="#DDE0E3" BorderThickness="1" Margin="0,0,0,8"
                         Text="Type to filter families..."
                         GotFocus="UI_Text_FamilyFilter_GotFocus"
                         LostFocus="UI_Text_FamilyFilter_LostFocus"
                         TextChanged="UI_Text_FamilyFilter_TextChanged"/>
                <ListBox x:Name="UI_List_Families" Grid.Row="4" Background="White"
                         BorderBrush="#E0E0E0" SelectionMode="Single" Margin="0,0,0,12"
                         SelectionChanged="UI_List_Families_SelectionChanged"/>

                <!-- Types Section -->
                <TextBlock Grid.Row="5" Text="Select Types to Load:" Style="{StaticResource PremiumSectionLabelStyle}" Margin="0,0,0,8"/>
                <TextBox x:Name="UI_Text_TypesFilter" Grid.Row="6" Height="30" Padding="8,0"
                         VerticalContentAlignment="Center" Background="#F9F9F9"
                         BorderBrush="#DDE0E3" BorderThickness="1" Margin="0,0,0,8"
                         Text="Type to filter types..."
                         GotFocus="UI_Text_TypesFilter_GotFocus"
                         LostFocus="UI_Text_TypesFilter_LostFocus"
                         TextChanged="UI_Text_TypesFilter_TextChanged"/>

                <!-- Types CheckedListBox equivalent using ListBox with CheckBoxes -->
                <ListBox x:Name="UI_List_Types" Grid.Row="7" Background="White"
                         BorderBrush="#E0E0E0" SelectionMode="Extended">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      Margin="4,2" FontSize="12"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="#FAFAFA" Padding="20,15" CornerRadius="0,0,12,12" BorderBrush="{StaticResource PremiumBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="UI_Status" Grid.Column="0" VerticalAlignment="Center" Foreground="#999999" Text="Ready to load • Family Loader"/>

                    <Button Grid.Column="1" Content="Uncheck All" Width="110" Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,0,10,0" Click="UI_Btn_UncheckAll_Click"/>
                    <Button Grid.Column="2" Content="Check All" Width="110" Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,0,10,0" Click="UI_Btn_CheckAll_Click"/>
                    <Button Grid.Column="3" Content="Cancel" Width="100" Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,0,10,0" Click="UI_Btn_Close_Click"/>
                    <Button x:Name="UI_Btn_Load" Grid.Column="4" Content="Load Families" Width="160" Style="{StaticResource PremiumActionButtonStyle}" Click="UI_Btn_Load_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
